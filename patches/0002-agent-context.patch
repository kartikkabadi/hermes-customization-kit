diff --git a/agent/context_files_mode.py b/agent/context_files_mode.py
new file mode 100644
index 0000000..1c0db60
--- /dev/null
+++ b/agent/context_files_mode.py
@@ -0,0 +1,34 @@
+"""Resolve the model-facing project-context strategy.
+
+Environment override remains available for experiments, while the config key
+makes the proven sparse/reference compilers usable by normal CLI, gateway,
+desktop, cron, and one-shot sessions without wrapper scripts.
+"""
+
+from __future__ import annotations
+
+import os
+
+_VALID_MODES = frozenset({"full", "reference", "sparse"})
+
+
+def resolve_context_files_mode() -> str:
+    """Return ``full``, ``reference``, or ``sparse`` with safe fallback.
+
+    ``HERMES_CONTEXT_FILES_MODE`` has explicit precedence for backwards-
+    compatible lab runs. Otherwise read the profile-scoped config. Invalid
+    values fail closed to the historical full-context behavior.
+    """
+    env_value = os.getenv("HERMES_CONTEXT_FILES_MODE")
+    if env_value is not None:
+        mode = env_value.strip().lower()
+        return mode if mode in _VALID_MODES else "full"
+
+    try:
+        from hermes_cli.config import load_config_readonly
+
+        mode = str(load_config_readonly().get("context_files_mode") or "full")
+        mode = mode.strip().lower()
+    except Exception:
+        return "full"
+    return mode if mode in _VALID_MODES else "full"
