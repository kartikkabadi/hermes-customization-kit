+def wrap_direct_deferred_tool_call(agent, tool_call) -> bool:
+    """Route a correct direct call through ``tool_call`` when its schema is paged.
+
+    Models often know common tool names even when progressive disclosure hides
+    their schemas. Rejecting a structurally valid, in-scope call forces a
+    search/describe/retry loop without adding safety. This wrapper changes only
+    the envelope; the executor later unwraps it and runs the usual scope gate,
+    middleware, approval, hooks, and handler path.
+    """
+    try:
+        function = tool_call.function
+        name = function.name
+        if (
+            name in agent.valid_tool_names
+            or "tool_call" not in agent.valid_tool_names
+            or name not in _tool_search_scoped_names(agent)
+        ):
+            return False
+        arguments = function.arguments
+        if isinstance(arguments, str):
+            arguments = json.loads(arguments)
+        if not isinstance(arguments, dict):
+            return False
+        function.name = "tool_call"
+        function.arguments = json.dumps(
+            {"name": name, "arguments": arguments},
+            separators=(",", ":"),
+            ensure_ascii=False,
+        )
+        return True
+    except (AttributeError, TypeError, ValueError, json.JSONDecodeError):
+        return False
+
+
