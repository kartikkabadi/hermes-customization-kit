+            "completed_action": arguments.get("action") or "capture",
+            "task_item_id": arguments.get("task_item_id"),
+            "task_step_id": arguments.get("task_step_id"),
+            "verified": payload.get("verified"),
+            "effect": payload.get("effect"),
+            "mode": payload.get("mode"),
+            "snapshot_id": payload.get("snapshot_id"),
+            "app": payload.get("app"),
+            "window_title": payload.get("window_title"),
+            "total_elements": payload.get("total_elements"),
+            "instruction": (
+                "A newer computer-use capture is authoritative. Do not use "
+                "element indices, tokens, coordinates, or visible state from "
+                "this superseded observation."
+            ),
+        }
+        projected_index = compacted_by_original_index[index]
