+        if message.get("role") != "tool" or tool_name != "computer_use":
+            continue
+        content = message.get("content")
+        if not isinstance(content, str):
+            continue
+        try:
+            payload = json.loads(content)
+        except (TypeError, ValueError):
+            continue
+        if not isinstance(payload, dict) or payload.get("mode") not in {"som", "ax", "vision"}:
+            continue
+        capture_indices.append(index)
+        parsed_captures[index] = payload
+
+    if len(capture_indices) < 2:
+        return messages
+
+    newest_index = capture_indices[-1]
+    drop_indices: set[int] = set()
+    for index in capture_indices[:-1]:
+        message = messages[index]
+        call_id = message.get("tool_call_id")
+        arguments = calls_by_id.get(call_id, {}) if isinstance(call_id, str) else {}
+        assistant_index = (
