+    ledger_pattern = re.compile(
+        re.escape(_VERIFIED_EFFECTS_BEGIN) + r"\s*(.*?)\s*" +
+        re.escape(_VERIFIED_EFFECTS_END), re.S,
+    )
+    for match in ledger_pattern.finditer(summary or ""):
+        for line in match.group(1).splitlines():
+            add(line.removeprefix("- ").strip())
+    clean_summary = ledger_pattern.sub("", summary or "").rstrip()
+
+    call_map: dict[str, tuple[str, dict[str, Any]]] = {}
+    for message in messages:
