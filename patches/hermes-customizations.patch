+"""Test the bounds rescaling that fixes the screen-vs-screenshot
+coordinate mismatch on Safari.
+
+cua-driver reports element bounds in the window's natural coordinate
+space (screen-relative). The screenshot is downsampled to fit
+max_image_dimension (default 1568). The wrapper must convert
+element bounds to the screenshot pixel space so the model can
+correctly click via element_index AND via coordinate=.
+
+Real Safari data:
+  AXWindow bounds: [9, 39, 1902, 1032]   (window is at screen 9,39, size 1902x1032)
+  Element [6] Grok bounds: [1836, 882, 55, 110]  (Grok button is at screen 1836,882)
+  Screenshot: 1568x851
+
+Expected scaled Grok:
+  scale_x = 1568 / 1902 = 0.8244
+  scale_y = 851 / 1032 = 0.8246
+  x = (1836 - 9) * 0.8244 = 1506
+  y = (882 - 39) * 0.8246 = 695
+  w = 55 * 0.8244 = 45
+  h = 110 * 0.8246 = 90
+
+Refs: branch fix/computer-use-safari, fix #8.
+"""
+
+from __future__ import annotations
+
+import os
+import sys
+
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", ".."))
+
+from tools.computer_use.backend import UIElement  # noqa: E402
+import tools.computer_use.cua_backend as cua  # noqa: E402
+
+
+def _make_capture_result():
+    """Return a fake CuaDriverBackend pre-loaded with Safari-style
+    elements and a 1568x851 screenshot, so we can drive capture()'s
+    rescale path end-to-end without a real daemon."""
+    # Build the elements in screen-coordinate space (the shape cua-driver
+    # reports BEFORE the wrapper rescales)
+    elems = [
+        UIElement(index=0, role="AXWindow", label="Home / X",
+                  bounds=(9, 39, 1902, 1032)),
+        UIElement(index=1, role="AXWebArea", label="Home / X",
+                  bounds=(9, 129, 1902, 10074)),
+        UIElement(index=2, role="AXButton", label="Grok",
+                  bounds=(1836, 882, 55, 110)),
+        UIElement(index=3, role="AXButton", label="Chat",
+                  bounds=(1836, 1004, 55, 55)),
+        UIElement(index=4, role="AXLink", label="Home",
+                  bounds=(335, 187, 260, 58)),
+    ]
+    # Fake 1568x851 PNG
+    import base64
+    # 1x1 PNG (we override width/height manually in the test)
+    png = base64.b64encode(b"\x89PNG\r\n\x1a\n" + b"\x00" * 24).decode()
+    return elems, png
+
+
+def test_rescale_safari_grok_to_screenshot_coords():
+    """The Safari 'Grok' button at screen (1836, 882) must end up
+    at screenshot (1506, 695) — within the 1568x851 image."""
+    # We can't easily call capture() without a full backend + session.
+    # Instead, replicate the rescale inline and verify the math.
+    width, height = 1568, 851
+    elems, _ = _make_capture_result()
+    win = next(e for e in elems if e.role == "AXWindow")
+    wx, wy, ww, wh = win.bounds
+    sx, sy = width / ww, height / wh
+    grok = next(e for e in elems if e.label == "Grok")
+    ex, ey, ew, eh = grok.bounds
+    nx = max(0, int((ex - wx) * sx))
+    ny = max(0, int((ey - wy) * sy))
+    nw = max(0, int(ew * sx))
+    nh = max(0, int(eh * sy))
+    assert (nx, ny, nw, nh) == (1506, 695, 45, 90), f"got {(nx, ny, nw, nh)}"
+    # Must be inside the screenshot bounds
+    assert 0 <= nx + nw <= width
+    assert 0 <= ny + nh <= height
+
+
+def test_rescale_clamps_negative_to_zero():
+    """An element positioned above / left of the window (off-viewport
+    on a virtualized DOM) must clamp to (0, 0) so the model doesn't
+    see a negative coord."""
+    elems = [
+        UIElement(index=0, role="AXWindow", label="x", bounds=(100, 100, 1000, 800)),
+        UIElement(index=1, role="AXLink", label="y", bounds=(-50, 200, 50, 30)),
+    ]
+    win = next(e for e in elems if e.role == "AXWindow")
+    wx, wy, ww, wh = win.bounds
+    width, height = 800, 640
+    sx, sy = width / ww, height / wh
+    link = next(e for e in elems if e.role == "AXLink")
+    ex, ey, ew, eh = link.bounds
+    nx = max(0, int((ex - wx) * sx))
+    ny = max(0, int((ey - wy) * sy))
+    assert nx == 0, f"expected clamp to 0; got {nx}"
+    assert ny >= 0
+
+
+def test_rescale_full_capture_path():
+    """End-to-end: feed a fake session returning the Safari payload
+    and verify the CaptureResult's element bounds are in screenshot
+    space, not screen space."""
+    import json
+    import base64
+    import struct
+
+    safari_payload = {
+        "elements": [
+            {"element_index": 0, "role": "AXWindow", "label": "Home / X",
+             "frame": {"x": 9, "y": 39, "w": 1902, "h": 1032}},
+            {"element_index": 2, "role": "AXButton", "label": "Grok",
+             "frame": {"x": 1836, "y": 882, "w": 55, "h": 110}},
+        ],
+        "screenshot_png_b64": "placeholder",  # will be replaced
+    }
+    # Build a real 1568x851 PNG so the wrapper's PNG dimension
+    # sniffing picks up the right size.
+    import zlib
+    def make_png(w, h):
+        sig = b"\x89PNG\r\n\x1a\n"
+        ihdr = struct.pack(">IIBBBBB", w, h, 8, 2, 0, 0, 0)  # 8-bit RGB
+        ihdr_chunk = b"IHDR" + ihdr
+        ihdr_full = struct.pack(">I", 13) + ihdr_chunk + struct.pack(">I", zlib.crc32(ihdr_chunk) & 0xFFFFFFFF)
+        # Minimal IDAT: one row of zeros
+        raw = b""
+        for _ in range(h):
+            raw += b"\x00" + b"\x00" * (w * 3)
+        idat = zlib.compress(raw)
+        idat_chunk = b"IDAT" + idat
+        idat_full = struct.pack(">I", len(idat)) + idat_chunk + struct.pack(">I", zlib.crc32(idat_chunk) & 0xFFFFFFFF)
+        iend = b"IEND"
+        iend_full = struct.pack(">I", 0) + iend + struct.pack(">I", zlib.crc32(iend) & 0xFFFFFFFF)
+        return sig + ihdr_full + idat_full + iend_full
+    real_png = make_png(1568, 851)
+    safari_payload["screenshot_png_b64"] = base64.b64encode(real_png).decode()
+
+    class FakeSession:
+        def _has_tool(self, name): return False
+        capabilities_discovered = True
+        def _populate_capabilities(self, session): pass
+        def call_tool(self, name, args, **kw):
+            return {
+                "list_windows": {
+                    "data": None, "structuredContent": {"windows": [
+                        {"app_name": "Safari", "pid": 75111, "window_id": 45363,
+                         "off_screen": False, "title": "X", "z_index": 0, "is_on_screen": True}
+                    ]}, "isError": False,
+                },
+                "get_window_state": {
+                    "data": safari_payload,
+                    "images": [safari_payload["screenshot_png_b64"]],
+                    "image_mime_types": ["image/png"],
+                    "structuredContent": safari_payload,
+                    "isError": False,
+                },
+            }.get(name, {"data": None, "structuredContent": {}, "isError": False})
+
+    backend = cua.CuaDriverBackend.__new__(cua.CuaDriverBackend)
+    backend._active_pid = 75111
+    backend._active_window_id = 45363
+    backend._last_app = None
+    backend._snapshot_tokens = {}
+    backend._session_id = "test"
+    backend._session = FakeSession()
+
+    result = backend.capture(mode="som", app="Safari")
+    assert result.width == 1568, f"width detection failed: {result.width}"
+    # Find the Grok element in the result
+    grok = next((e for e in result.elements if e.label == "Grok"), None)
+    assert grok is not None, "Grok element missing"
+    # The bounds MUST be in screenshot space (scaled + offset)
+    # screenshot is 1568x851, window was [9, 39, 1902, 1032]
+    # expected Grok: (1506, 695, 45, 90) (int rounding)
+    assert grok.bounds == (1506, 695, 45, 90), f"got {grok.bounds}"
diff --git a/tests/computer_use/test_browser_sparsity_hint.py b/tests/computer_use/test_browser_sparsity_hint.py
