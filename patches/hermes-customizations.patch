+++ b/tests/computer_use/test_capture_defaults.py
@@ -0,0 +1,317 @@
+"""Test the per-app capture defaults wired into cua-driver's
+get_window_state args.
+
+Two surfaces to cover:
+
+  1. _load_capture_defaults() — read config.yaml, fail safe on errors,
+     validate types, cache for the process lifetime.
+
+  2. _resolve_capture_args() — pick the right override for the given
+     app name (per-app wins over global, screen/desktop sentinel
+     returns global only).
+
+The end-to-end capture() call-site injection is covered by running
+capture() against a mock backend and asserting the args it passes
+to get_window_state.
+
+Refs: branch fix/computer-use-safari, fix #2 of 6.
+"""
+
+from __future__ import annotations
+
+import json
+import os
+import sys
+from unittest.mock import patch
+
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", ".."))
+
+import tools.computer_use.cua_backend as cua  # noqa: E402
+
+
+def _reset_cache():
+    cua._CAPTURE_DEFAULTS_CACHE = None
+
+
+def test_load_returns_empty_when_no_config():
+    _reset_cache()
+    with patch.object(cua, "load_config", create=True, side_effect=ImportError):
+        result = cua._load_capture_defaults()
+    assert result == {"global": {}, "apps": {}}
+
+
+def test_load_returns_empty_when_config_empty():
+    _reset_cache()
+    with patch.dict("sys.modules", {"hermes_cli.config": __import__("types").ModuleType("hc")}):
+        hc = sys.modules["hermes_cli.config"]
+        hc.load_config = lambda: None
+        result = cua._load_capture_defaults()
+    assert result == {"global": {}, "apps": {}}
+
+
+def test_load_reads_global_and_apps():
+    _reset_cache()
+    fake_config = {
+        "computer_use": {
+            "capture_defaults": {
+                "global": {"max_elements": 300, "max_depth": 15, "query": "button"},
+                "apps": {
+                    "Safari": {"max_elements": 250, "max_depth": 12},
+                    "Google Chrome": {"query": "link"},
+                },
+            }
+        }
+    }
+    with patch.dict("sys.modules", {"hermes_cli.config": __import__("types").ModuleType("hc")}):
+        hc = sys.modules["hermes_cli.config"]
+        hc.load_config = lambda: fake_config
+        result = cua._load_capture_defaults()
+    assert result["global"] == {"max_elements": 300, "max_depth": 15, "query": "button"}
+    assert result["apps"]["Safari"] == {"max_elements": 250, "max_depth": 12}
+    assert result["apps"]["Google Chrome"] == {"query": "link"}
+
+
+def test_load_drops_unknown_keys():
+    _reset_cache()
+    fake_config = {
+        "computer_use": {
+            "capture_defaults": {
+                "global": {"max_elements": 100, "evil_key": "x"},
+                "apps": {"Safari": {"max_elements": 50, "another_evil": True}},
+            }
+        }
+    }
+    with patch.dict("sys.modules", {"hermes_cli.config": __import__("types").ModuleType("hc")}):
+        hc = sys.modules["hermes_cli.config"]
+        hc.load_config = lambda: fake_config
+        result = cua._load_capture_defaults()
+    assert "evil_key" not in result["global"]
+    assert "another_evil" not in result["apps"]["Safari"]
+
+
+def test_load_clamps_max_values():
+    _reset_cache()
+    fake_config = {
+        "computer_use": {
+            "capture_defaults": {
+                "global": {"max_elements": 99999, "max_depth": -5},
+            }
+        }
+    }
+    with patch.dict("sys.modules", {"hermes_cli.config": __import__("types").ModuleType("hc")}):
+        hc = sys.modules["hermes_cli.config"]
+        hc.load_config = lambda: fake_config
+        result = cua._load_capture_defaults()
+    # max_elements clamps to 5000 (ceil of config)
+    assert result["global"]["max_elements"] == 5000
+    # max_depth negative → clamped up to 1
+    assert result["global"]["max_depth"] == 1
+
+
+def test_load_caches_for_lifetime():
+    _reset_cache()
+    with patch.dict("sys.modules", {"hermes_cli.config": __import__("types").ModuleType("hc")}):
+        hc = sys.modules["hermes_cli.config"]
+        calls = []
+        def fake_load():
+            calls.append(1)
+            return {"computer_use": {"capture_defaults": {"global": {"max_elements": 100}, "apps": {}}}}
+        hc.load_config = fake_load
+        cua._load_capture_defaults()
+        cua._load_capture_defaults()
+        cua._load_capture_defaults()
+        assert len(calls) == 1, "config must be cached after first read"
+
+
+def test_resolve_returns_global_when_no_app():
+    _reset_cache()
+    fake_config = {
+        "computer_use": {
+            "capture_defaults": {
+                "global": {"max_elements": 300, "max_depth": 15},
+                "apps": {"Safari": {"max_elements": 250}},
+            }
+        }
+    }
+    with patch.dict("sys.modules", {"hermes_cli.config": __import__("types").ModuleType("hc")}):
+        hc = sys.modules["hermes_cli.config"]
+        hc.load_config = lambda: fake_config
+        # No app name → just global
+        result = cua._resolve_capture_args("")
+        assert result == {"max_elements": 300, "max_depth": 15}
+        # App name with no override → global
+        result = cua._resolve_capture_args("Finder")
+        assert result == {"max_elements": 300, "max_depth": 15}
+
+
+def test_resolve_app_specific_overrides_global():
+    _reset_cache()
+    fake_config = {
+        "computer_use": {
+            "capture_defaults": {
+                "global": {"max_elements": 300, "max_depth": 15, "query": "button"},
+                "apps": {
+                    "Safari": {"max_elements": 250, "max_depth": 12},
+                },
+            }
+        }
+    }
+    with patch.dict("sys.modules", {"hermes_cli.config": __import__("types").ModuleType("hc")}):
+        hc = sys.modules["hermes_cli.config"]
+        hc.load_config = lambda: fake_config
+        # Per-app overrides win on overlap, global supplies the rest
+        result = cua._resolve_capture_args("Safari")
+        assert result["max_elements"] == 250
+        assert result["max_depth"] == 12
+        assert result["query"] == "button"  # inherited from global
+
+
+def test_resolve_screen_sentinel_skips_app_lookup():
+    _reset_cache()
+    fake_config = {
+        "computer_use": {
+            "capture_defaults": {
+                "global": {"max_elements": 300},
+                "apps": {"Safari": {"max_elements": 50}},
+            }
+        }
+    }
+    with patch.dict("sys.modules", {"hermes_cli.config": __import__("types").ModuleType("hc")}):
+        hc = sys.modules["hermes_cli.config"]
+        hc.load_config = lambda: fake_config
+        result = cua._resolve_capture_args("screen")
+        assert result["max_elements"] == 300
+
+
+def test_resolve_substring_match():
+    _reset_cache()
+    fake_config = {
+        "computer_use": {
+            "capture_defaults": {
+                "apps": {"Chrome": {"max_elements": 200}},
+            }
+        }
+    }
+    with patch.dict("sys.modules", {"hermes_cli.config": __import__("types").ModuleType("hc")}):
+        hc = sys.modules["hermes_cli.config"]
+        hc.load_config = lambda: fake_config
+        # "Google Chrome" contains "chrome" — substring match wins
+        result = cua._resolve_capture_args("Google Chrome")
+        assert result["max_elements"] == 200
+
+
+def test_browser_capture_raises_node_cap_but_preserves_other_overrides():
+    """Browser chrome gets a bounded walk beyond a low configured cap."""
+    _reset_cache()
+    fake_config = {
+        "computer_use": {
+            "capture_defaults": {
+                "apps": {"Safari": {"max_elements": 250, "max_depth": 12, "query": "button"}},
+            }
+        }
+    }
+    with patch.dict("sys.modules", {"hermes_cli.config": __import__("types").ModuleType("hc")}):
+        hc = sys.modules["hermes_cli.config"]
+        hc.load_config = lambda: fake_config
+
+        from tools.computer_use.backend import CaptureResult
+        backend = cua.CuaDriverBackend.__new__(cua.CuaDriverBackend)
+        backend._active_pid = 75111
+        backend._active_window_id = 45363
+        backend._last_app = None
+        backend._snapshot_tokens = {}
+        backend._session_id = "test"
+        backend._session = type("FakeSession", (), {})()
+        backend._session._has_tool = lambda name: False
+        backend._session.capabilities_discovered = True
+        backend._session._populate_capabilities = lambda session: None
+
+        calls = []
+        def _record_call(name, args, **kw):
+            calls.append((name, args))
+            if name == "list_windows":
+                return {"data": None, "structuredContent": {"windows": [
+                    {"app_name": "Safari", "pid": 75111, "window_id": 45363,
+                     "off_screen": False, "title": "Home / X", "z_index": 0, "is_on_screen": True}
+                ]}, "isError": False}
+            if name == "get_window_state":
+                return {
+                    "data": json.dumps({"element_count": 1, "tree_markdown": ""}),
+                    "images": ["A" * 100],
+                    "image_mime_types": ["image/png"],
+                    "structuredContent": {
+                        "elements": [{"element_index": 0, "role": "AXWindow", "label": "x", "frame": {"x":0,"y":0,"w":10,"h":10}}],
+                        "screenshot_png_b64": "A" * 100,
+                        "tree_markdown": "",
+                    },
+                    "isError": False,
+                }
+            return {"data": None, "structuredContent": {}, "isError": False}
+        backend._session.call_tool = _record_call
+
+        result = backend.capture(mode="som", app="Safari")
+        assert isinstance(result, CaptureResult)
+
+        gws_calls = [args for name, args in calls if name == "get_window_state"]
+        assert gws_calls, "expected at least one get_window_state call"
+        for args in gws_calls:
+            assert args.get("max_elements") == 2500, f"unexpected browser cap in {args}"
+            assert args.get("max_depth") == 12, f"missing max_depth in {args}"
+            assert args.get("query") == "button", f"missing query in {args}"
+
+def test_capture_ax_mode_skips_screenshot():
+    """mode='ax' must pass include_screenshot=False to get_window_state
+    so cua-driver drops the screenshot server-side — saves 100-400 KB
+    of base64 per call on dense web apps. The vision / som paths must
+    keep include_screenshot=True so the model still sees the pixels."""
+    _reset_cache()
+    # No capture_defaults needed
+    with patch.dict("sys.modules", {"hermes_cli.config": __import__("types").ModuleType("hc")}):
+        hc = sys.modules["hermes_cli.config"]
+        hc.load_config = lambda: None
+
+        from tools.computer_use.backend import CaptureResult
+        backend = cua.CuaDriverBackend.__new__(cua.CuaDriverBackend)
+        backend._active_pid = 75111
+        backend._active_window_id = 45363
+        backend._last_app = None
+        backend._snapshot_tokens = {}
+        backend._session_id = "test"
+        backend._session = type("FakeSession", (), {})()
+        backend._session._has_tool = lambda name: False
+        backend._session.capabilities_discovered = True
+        backend._session._populate_capabilities = lambda session: None
+
+        # Track every get_window_state's include_screenshot value
+        recorded = []
+        def _record(name, args, **kw):
+            if name == "list_windows":
+                return {"data": None, "structuredContent": {"windows": [
+                    {"app_name": "Finder", "pid": 467, "window_id": 1,
+                     "off_screen": False, "title": "x", "z_index": 0, "is_on_screen": True}
+                ]}, "isError": False}
+            if name == "get_window_state":
+                recorded.append(args.get("include_screenshot"))
+                return {
+                    "data": json.dumps({"element_count": 1, "tree_markdown": ""}),
+                    "images": [],
+                    "image_mime_types": [],
+                    "structuredContent": {
+                        "elements": [{"element_index": 0, "role": "AXWindow", "label": "x", "frame": {"x":0,"y":0,"w":10,"h":10}}],
+                        "tree_markdown": "",
+                    },
+                    "isError": False,
+                }
+            return {"data": None, "structuredContent": {}, "isError": False}
+        backend._session.call_tool = _record
+
+        backend.capture(mode="ax")
+        assert recorded == [False], f"ax mode must pass include_screenshot=False; got {recorded}"
+
+        recorded.clear()
+        backend.capture(mode="som")
+        assert recorded == [True], f"som mode must pass include_screenshot=True; got {recorded}"
+
+        recorded.clear()
+        backend.capture(mode="vision")
+        assert recorded == [True], f"vision mode must pass include_screenshot=True; got {recorded}"
diff --git a/tests/computer_use/test_extract_cua_payload.py b/tests/computer_use/test_extract_cua_payload.py
new file mode 100644
index 000000000..212ee31b0
--- /dev/null
+++ b/tests/computer_use/test_extract_cua_payload.py
@@ -0,0 +1,270 @@
+"""Regression test: _extract_tool_result must surface cua-driver's
+per-tool JSON payload (with `elements` / `screenshot_png_b64` /
+`tree_markdown` at the top level) as `structuredContent`.
+
+Background: cua-driver's MCP response puts the structured payload in the
+text content part, NOT in the MCP protocol-level `structuredContent` field.
+Without this promotion, `capture()` falls through to a lossy markdown regex
+that drops every element's bounds — the dominant Safari failure mode
+(branch: fix/computer-use-safari).
+"""
+
+from __future__ import annotations
+
+import json
+import os
+import sys
+from types import SimpleNamespace
+from typing import Any, Dict, List, Optional
+
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", ".."))
+
+from tools.computer_use.cua_backend import _extract_tool_result  # noqa: E402
+
+
+FIXTURE_DIR = os.path.join(os.path.dirname(__file__), "fixtures")
+
+
+def _text_part(text: str) -> Any:
+    return SimpleNamespace(type="text", text=text)
+
+
+def _image_part(b64: str, mime: str = "image/png") -> Any:
+    return SimpleNamespace(type="image", data=b64, mimeType=mime)
+
+
+def _result(
+    *,
+    text: Optional[str] = None,
+    parts: Optional[List[Any]] = None,
+    structured: Optional[Dict[str, Any]] = None,
+    is_error: bool = False,
+) -> Any:
+    content = parts if parts is not None else ([_text_part(text)] if text else [])
+    return SimpleNamespace(
+        content=content,
+        structuredContent=structured,
+        isError=is_error,
+    )
+
+
+def _load_fixture(name: str) -> Dict[str, Any]:
+    with open(os.path.join(FIXTURE_DIR, name)) as f:
+        return json.load(f)
+
+
+def test_safari_payload_promoted_to_structured_content():
+    """The real cua-driver response for a Safari capture carries
+    `elements` / `tree_markdown` / `screenshot_png_b64` at the top level
+    of the text part. After _extract_tool_result, those must be visible
+    on `out["structuredContent"]` so capture() can pick them up.
+    """
+    payload = _load_fixture("safari_window_state_small.json")
+    # The fixture was captured without a screenshot; add a fake base64
+    # so the dedup path is exercised.
+    payload["screenshot_png_b64"] = "A" * 2048
+    text = json.dumps(payload)
+
+    out = _extract_tool_result(_result(text=text))
+
+    # structuredContent must carry the cua-driver payload.
+    sc = out.get("structuredContent")
+    assert isinstance(sc, dict), f"expected dict, got {type(sc).__name__}"
+    assert "elements" in sc, "cua-driver `elements` array missing from structuredContent"
+    assert "screenshot_png_b64" in sc, "cua-driver `screenshot_png_b64` missing"
+    assert "tree_markdown" in sc, "cua-driver `tree_markdown` missing"
+    assert "snapshot_id" in sc, "cua-driver `snapshot_id` missing"
+    assert len(sc["elements"]) == len(payload["elements"])
+
+
+def test_safari_payload_drops_doubled_screenshot_in_data_string():
+    """When the text part carries a >1KB base64 screenshot, the legacy
+    `data` string must NOT also carry the full base64 — it should be
+    a lean JSON without `screenshot_png_b64`. Doubling wastes context
+    tokens on every capture.
+    """
+    payload = {"elements": [{"element_index": 0, "role": "AXWindow", "label": "x"}], "screenshot_png_b64": "B" * 5000}
+    text = json.dumps(payload)
+    out = _extract_tool_result(_result(text=text))
+    data_str = out["data"] if isinstance(out["data"], str) else json.dumps(out["data"])
+    assert "B" * 100 not in data_str, "legacy `data` field still carries the base64 screenshot"
+    assert "screenshot_png_b64" not in data_str, "lean `data` still references screenshot_png_b64"
+
+
+def test_legacy_structured_content_still_works():
+    """MCP protocol-level structuredContent (separate from text part)
+    must still be surfaced — some MCP servers / cua-driver surfaces
+    use it. Both paths must compose.
+    """
+    out = _extract_tool_result(_result(
+        text=json.dumps({"elements": [{"element_index": 0}], "tree_markdown": "x"}),
+        structured={"windows": [{"window_id": 1}]},
+    ))
+    sc = out["structuredContent"]
+    # Both must be present in the merged result.
+    assert "elements" in sc
+    assert "windows" in sc
+
+
+def test_non_payload_text_passes_through_unchanged():
+    """A text part that's NOT a cua-driver payload (no sentinel keys)
+    must surface as `data` (parsed if JSON) without being promoted to
+    structuredContent.
+    """
+    out = _extract_tool_result(_result(text='{"ok": true, "msg": "hi"}'))
+    assert out["structuredContent"] is None
+    assert out["data"] == {"ok": True, "msg": "hi"}
+
+
+def test_plain_text_passes_through_unchanged():
+    """A non-JSON text part is just data, no structured payload."""
+    out = _extract_tool_result(_result(text="some plain status text"))
+    assert out["data"] == "some plain status text"
+    assert out["structuredContent"] is None
+
+
+def test_image_parts_carry_mime_type():
+    """Each image part's mimeType must be captured in `image_mime_types`,
+    parallel to `images`. Image content stays in `images` and is not
+    promoted to structuredContent.
+    """
+    out = _extract_tool_result(_result(parts=[
+        _image_part("A" * 100, mime="image/png"),
+        _image_part("B" * 100, mime="image/jpeg"),
+    ]))
+    assert out["images"] == ["A" * 100, "B" * 100]
+    assert out["image_mime_types"] == ["image/png", "image/jpeg"]
+
+
+def test_cua_payload_with_no_screenshot_keeps_data_unchanged():
+    """When the payload is small (no big screenshot), `data` is the
+    parsed dict itself — legacy consumers (list_apps, _action) read
+    `out["data"]` as a dict for action metadata, and the SOM-mode
+    capture path in cua_backend only needs the markdown tree out of
+    the joined string. We surface the dict in BOTH data and
+    structuredContent for that reason; the dedup branch only fires
+    on >1KB screenshot to avoid the heavy doubling there."""
+    payload = {"elements": [{"element_index": 0}], "tree_markdown": "x" * 200}
+    text = json.dumps(payload)
+    out = _extract_tool_result(_result(text=text))
+    # `data` is the dict (mirrors structuredContent for small payloads)
+    assert out["data"] == payload
+    assert out["structuredContent"] == payload
+
+
+def test_is_error_propagates():
+    out = _extract_tool_result(_result(
+        text=json.dumps({"elements": [], "error": "boom"}),
+        is_error=True,
+    ))
+    assert out["isError"] is True
+
+
+def test_list_apps_payload_promoted_to_structured_content():
+    """list_apps returns a top-level dict with `apps` key. With the
+    wider heuristic, every cua-driver tool's payload gets promoted —
+    not just the ones with the original sentinel keys."""
+    payload = {"apps": [{"name": "Finder", "pid": 467}, {"name": "Safari", "pid": 75111}]}
+    out = _extract_tool_result(_result(text=json.dumps(payload)))
+    sc = out.get("structuredContent")
+    assert isinstance(sc, dict)
+    assert "apps" in sc
+    assert len(sc["apps"]) == 2
+
+
+def test_get_cursor_position_promoted():
+    """get_cursor_position returns {x, y} with no overlap to the original
+    sentinel keys. The wider heuristic must still promote it so the
+    backend's read path (which calls out.get("structuredContent"))
+    gets the coordinates."""
+    payload = {"x": 480, "y": 311}
+    out = _extract_tool_result(_result(text=json.dumps(payload)))
+    sc = out.get("structuredContent")
+    assert isinstance(sc, dict)
+    assert sc["x"] == 480
+    assert sc["y"] == 311
+
+
+def test_get_screen_size_promoted():
+    payload = {"width": 1920, "height": 1080, "scale_factor": 1.0}
+    out = _extract_tool_result(_result(text=json.dumps(payload)))
+    sc = out.get("structuredContent")
+    assert isinstance(sc, dict)
+    assert sc["width"] == 1920
+    assert sc["height"] == 1080
+
+
+def test_top_level_list_promoted():
+    """Some cua-driver tools return a JSON array at the top level. Wrap
+    it in a {"data": [...]} payload so the consumer's structuredContent
+    path still finds it."""
+    payload = [{"name": "Finder", "pid": 467}]
+    out = _extract_tool_result(_result(text=json.dumps(payload)))
+    sc = out.get("structuredContent")
+    assert isinstance(sc, dict)
+    assert sc.get("data") == payload
+
+
+def test_status_shape_not_promoted():
+    """Tool reply shaped as a status / error (only `ok` / `message` /
+    `error` / `hint` keys) must NOT be promoted to structuredContent —
+    consumers that read the legacy `data` field would break."""
+    out = _extract_tool_result(_result(text=json.dumps({"ok": True, "message": "saved"})))
+    assert out["structuredContent"] is None
+    assert out["data"] == {"ok": True, "message": "saved"}
+
+
+def test_error_shape_not_promoted():
+    out = _extract_tool_result(_result(text=json.dumps({"error": "boom", "hint": "try again"})))
+    assert out["structuredContent"] is None
+    assert out["data"] == {"error": "boom", "hint": "try again"}
+
+
+def test_legacy_protocol_structured_content_still_works():
+    """MCP protocol-level structuredContent (separate from text part)
+    must still be surfaced — some MCP servers / cua-driver surfaces
+    use it. Both paths must compose."""
+    out = _extract_tool_result(_result(
+        text=json.dumps({"elements": [{"element_index": 0}], "tree_markdown": "x"}),
+        structured={"windows": [{"window_id": 1}]},
+    ))
+    sc = out["structuredContent"]
+    # Both must be present in the merged result.
+    assert "elements" in sc
+    assert "windows" in sc
+
+
+def test_action_data_field_is_dict_for_action_metadata():
+    """The legacy `data` field for action calls (set_value, click, etc.)
+    is read by _action() as a dict for action metadata. The wrapper
+    must surface the parsed dict, not the JSON string, so action
+    metadata like {ok: true, message: ...} flows through correctly.
+
+    Action replies (e.g. {ok: true, message: "clicked"}) are status
+    shapes — _looks_like_cua_payload correctly does NOT promote them
+    to structuredContent. They flow through the legacy `data` field
+    where _action() reads them.
+    """
+    # Real cua-driver click() response shape:
+    payload = {"ok": True, "message": "clicked element 5"}
+    out = _extract_tool_result(_result(text=json.dumps(payload)))
+    # `data` is the parsed dict — _action's isinstance(data, dict) check
+    # works, and it reads data.get("message") for the ActionResult.
+    assert isinstance(out["data"], dict)
+    assert out["data"].get("ok") is True
+    assert out["data"].get("message") == "clicked element 5"
+    # structuredContent is NOT populated for status shapes (that's the
+    # whole point of the heuristic — keep the legacy path alive).
+    assert out["structuredContent"] is None
+
+
+def test_list_apps_data_is_list():
+    """list_apps reads `out["data"]` as a list when it's a list (the
+    parsed payload). The wrapper must surface the parsed shape, not
+    the JSON string."""
+    payload = [{"name": "Finder", "pid": 467, "running": True, "windows": []}]
+    out = _extract_tool_result(_result(text=json.dumps(payload)))
+    assert isinstance(out["data"], list)
+    assert len(out["data"]) == 1
+    # structuredContent wraps the list
+    assert out["structuredContent"].get("data") == payload
diff --git a/tests/computer_use/test_filter_passive_elements.py b/tests/computer_use/test_filter_passive_elements.py
new file mode 100644
index 000000000..0848eb6f8
--- /dev/null
+++ b/tests/computer_use/test_filter_passive_elements.py
@@ -0,0 +1,151 @@
+"""Test _filter_passive_elements against an anonymized Safari AX tree.
+
+The fixture preserves the roles, frames, and parent relationships from a
+CuaDriver 0.7.1 capture while replacing all captured page text.
+
+Refs: branch fix/computer-use-safari, fix #3 of 6.
+"""
+
+from __future__ import annotations
+
+import json
+import os
+import sys
+
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", ".."))
+
+from tools.computer_use.backend import UIElement  # noqa: E402
+from tools.computer_use.cua_backend import (  # noqa: E402
+    _filter_passive_elements,
+    _parse_elements_from_structured,
+)
+
+FIXTURE = os.path.join(
+    os.path.dirname(__file__), "fixtures", "safari_window_state_web.json"
+)
+
+
+def _fixture_elements() -> list:
+    with open(FIXTURE) as f:
+        payload = json.load(f)
+    return _parse_elements_from_structured(payload["elements"])
+
+
+def test_fixture_loads_clean():
+    elems = _fixture_elements()
+    assert len(elems) == 154, f"unexpected fixture size: {len(elems)}"
+    # every element must have a role
+    for e in elems:
+        assert e.role, f"element {e.index} missing role"
+
+
+def test_filter_drops_static_text_shadows():
+    elems = _fixture_elements()
+    static_text_before = sum(1 for e in elems if e.role == "AXStaticText")
+    assert static_text_before > 0, "fixture must contain AXStaticText shadows"
+    filtered = _filter_passive_elements(elems)
+    static_text_after = sum(1 for e in filtered if e.role == "AXStaticText")
+    assert static_text_after == 0, "filter must drop all AXStaticText entries"
+    # And the actual count reduction should be meaningful
+    assert len(filtered) < len(elems), "filter should remove some elements"
+
+
+def test_filter_keeps_ax_window():
+    """The top-level AXWindow is the only one with the title — always keep."""
+    elems = _fixture_elements()
+    windows = [e for e in elems if e.role == "AXWindow"]
+    assert len(windows) == 1
+    filtered = _filter_passive_elements(elems)
+    assert any(e.role == "AXWindow" for e in filtered)
+
+
+def test_filter_keeps_labeled_actionable_roles():
+    """Buttons, links, text fields, popup buttons that DO carry a
+    visible surface (label + frame) must survive the filter — those
+    are the elements the model actually wants to click. The filter is
+    allowed to drop unlabeled / no-frame entries even from the
+    "actionable" role set, because cua-driver exposes them as
+    ghost containers (e.g. an AXMenu with no title and no bounds is
+    a parent, not a click target).
+    """
+    elems = _fixture_elements()
+    actionable_with_surface = {
+        "AXButton", "AXLink", "AXTextField", "AXPopUpButton",
+        "AXCheckBox", "AXRadioButton", "AXComboBox", "AXMenuItem",
+        "AXMenuBarItem", "AXTabGroup", "AXSlider", "AXIncrementor",
+        "AXColorWell", "AXMenuButton",
+    }
+    # Identify labeled+framed actionable elements that should survive
+    should_survive = [
+        e for e in elems
+        if e.role in actionable_with_surface
+        and (e.label or "").strip()
+        and e.bounds != (0, 0, 0, 0)
+    ]
+    assert len(should_survive) > 0, "fixture must have labeled actionable elements"
+    filtered = _filter_passive_elements(elems)
+    filtered_ids = {e.index for e in filtered}
+    for e in should_survive:
+        assert e.index in filtered_ids, (
+            f"labeled+framed {e.role!r} (label={e.label!r}) was dropped"
+        )
+
+
+def test_filter_drops_unlabeled_no_frame_ghosts():
+    elems = _fixture_elements()
+    # build a synthetic ghost
+    ghost = UIElement(index=9999, role="AXUnknown", label="", bounds=(0, 0, 0, 0))
+    elems = elems + [ghost]
+    filtered = _filter_passive_elements(elems)
+    assert not any(e.index == 9999 for e in filtered)
+
+
+def test_filter_keeps_unlabeled_with_real_frame():
+    """An element with no label but a real frame is still a clickable
+    surface (e.g. an icon button) — keep it."""
+    elems = _fixture_elements()
+    icon = UIElement(index=9998, role="AXButton", label="", bounds=(100, 100, 32, 32))
+    elems = elems + [icon]
+    filtered = _filter_passive_elements(elems)
+    kept = [e for e in filtered if e.index == 9998]
+    assert len(kept) == 1, "unlabeled AXButton with a real frame must be kept"
+
+
+def test_filter_can_be_disabled():
+    elems = _fixture_elements()
+    static_text_before = sum(1 for e in elems if e.role == "AXStaticText")
+    # disabling drop_passive must preserve static text
+    filtered = _filter_passive_elements(elems, drop_passive=False, drop_unlabeled=False)
+    static_text_after = sum(1 for e in filtered if e.role == "AXStaticText")
+    assert static_text_after == static_text_before
+    assert len(filtered) == len(elems)
+
+
+def test_filter_drops_only_unlabeled_ghosts_when_passive_off():
+    elems = _fixture_elements()
+    ghost = UIElement(index=9997, role="AXUnknown", label="", bounds=(0, 0, 0, 0))
+    elems = elems + [ghost]
+    # passive off, unlabeled on → still drops the ghost, keeps static text
+    filtered = _filter_passive_elements(elems, drop_passive=False, drop_unlabeled=True)
+    assert not any(e.index == 9997 for e in filtered)
+    static_text_after = sum(1 for e in filtered if e.role == "AXStaticText")
+    static_text_before = sum(1 for e in elems if e.role == "AXStaticText")
+    assert static_text_after == static_text_before
+
+
+def test_filter_handles_empty_list():
+    assert _filter_passive_elements([]) == []
+
+
+def test_filter_safari_shape_reduces_size_materially():
+    """The anonymized Safari web fixture must shrink by a meaningful amount
+    (we expect ~15-25% reduction just from AXStaticText alone on a
+    typical web page)."""
+    elems = _fixture_elements()
+    before = len(elems)
+    filtered = _filter_passive_elements(elems)
+    after = len(filtered)
+    reduction_pct = (before - after) / before * 100
+    # Sanity: at least 5% reduction. Real Safari captures typically
+    # see 15-20% from this filter.
+    assert reduction_pct >= 5, f"filter reduced {before} → {after} ({reduction_pct:.1f}%); expected >= 5%"
