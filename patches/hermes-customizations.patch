+def _controller_preflight(
+    backend: ComputerUseBackend, action: str, args: Dict[str, Any],
+) -> Optional[str]:
+    """Enforce exact-count and retry invariants before a repeated-task mutation."""
+    state = getattr(backend, "_controller_task", None)
+    if action.startswith("task_"):
+        return None
+    is_mutation = action in _DESTRUCTIVE_ACTIONS or (
+        action == "page"
+        and str(args.get("page_action") or "") in _DESTRUCTIVE_PAGE_ACTIONS
+    )
+    if not isinstance(state, dict) or not is_mutation:
+        return None
+    if (
+        state.get("confirmed")
+        and state.get("authorization_source") == "standing_goal"
+        and not _standing_goal_lease_valid(state)
+    ):
+        state["confirmed"] = False
+        state["authorization_suspended_at"] = time.time()
+        _save_persistent_task(state)
+    completed = state.get("completed_item_ids") or []
+    if len(completed) >= int(state.get("target_count") or 0):
+        return json.dumps({
+            "ok": False,
+            "status": "task_complete",
+            "next_action": "answer_user",
+            "task": state,
+        })
+    if state.get("irreversible") and not state.get("confirmed"):
+        if _authorize_task_from_standing_goal(state):
