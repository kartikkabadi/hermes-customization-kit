+                "action": "sequence",
+                "status": "stale_target",
+                "error": f"sequence {field} does not match the latest capture",
+                "target": {"expected": expected, "received": supplied},
+            })
+
+    step_results: List[Dict[str, Any]] = []
+    failed_at: Optional[int] = None
+    for index, raw_step in enumerate(steps):
+        step = dict(raw_step)
+        step_action = str(step.pop("action", "")).strip().lower()
+        if step_action not in _SEQUENCE_STEP_ACTIONS:
+            failed_at = index
