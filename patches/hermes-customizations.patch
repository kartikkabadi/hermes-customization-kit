index 000000000..dc78df462
--- /dev/null
+++ b/tests/computer_use/test_browser_sparsity_hint.py
@@ -0,0 +1,97 @@
+"""Test browser-sparsity detection that recommends the cua-driver
+`page` tool when the AX walk comes back mostly frame-less.
+
+Safari / Chrome-family browsers expose web content as a single
+AXWebArea with the actual DOM nodes buried inside the browser
+process — cua-driver's AX walk often returns AX elements with
+no usable frame, which makes element_index clicks blind. The
+`page` tool (CDP / Apple Events / UIA-WebView) is the reliable
+path on these surfaces.
+
+Refs: branch fix/computer-use-safari, fix #4 of 6.
+"""
+
+from __future__ import annotations
+
+import os
+import sys
+
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", ".."))
+
+from tools.computer_use.backend import UIElement  # noqa: E402
+from tools.computer_use.cua_backend import (  # noqa: E402
+    _ax_sparsity_score,
+    _is_browser_app,
+    _BROWSER_APP_HINTS,
+)
+
+
+def test_is_browser_app_known_browsers():
+    for name in ("Safari", "Google Chrome", "Chrome", "Brave", "Brave Browser",
+                 "Microsoft Edge", "Edge", "Arc", "Opera", "Vivaldi",
+                 "DuckDuckGo", "Chromium", "Helium"):
+        assert _is_browser_app(name), f"{name!r} should be a browser"
+
+
+def test_is_browser_app_unknown_apps():
+    for name in ("Finder", "Notes", "Terminal", "Slack", "VS Code", ""):
+        assert not _is_browser_app(name), f"{name!r} should not be a browser"
+
+
+def test_is_browser_app_is_exact_match():
+    # substring matching would be too loose (e.g. "Safari Technology Preview"
+    # would match but is a different app)
+    assert not _is_browser_app("Safari Technology Preview")
+    assert not _is_browser_app("Chrome Canary")
+
+
+def test_ax_sparsity_score_empty():
+    assert _ax_sparsity_score([]) == 0.0
+
+
+def test_ax_sparsity_score_all_framed():
+    elems = [
+        UIElement(index=i, role="AXButton", label="x", bounds=(0, 0, 10, 10))
+        for i in range(5)
+    ]
+    assert _ax_sparsity_score(elems) == 0.0
+
+
+def test_ax_sparsity_score_all_unframed():
+    elems = [
+        UIElement(index=i, role="AXWebArea", label="", bounds=(0, 0, 0, 0))
+        for i in range(5)
+    ]
+    assert _ax_sparsity_score(elems) == 1.0
+
+
+def test_ax_sparsity_score_mixed():
+    elems = [
+        UIElement(index=0, role="AXWindow", label="x", bounds=(0, 0, 100, 100)),
+        UIElement(index=1, role="AXButton", label="", bounds=(0, 0, 0, 0)),
+        UIElement(index=2, role="AXLink", label="", bounds=(0, 0, 0, 0)),
+        UIElement(index=3, role="AXStaticText", label="hi", bounds=(50, 50, 80, 20)),
+    ]
+    # 2 of 4 have no frame → 0.5
+    assert _ax_sparsity_score(elems) == 0.5
+
+
+def test_ax_sparsity_score_negative_dimensions_treated_as_no_frame():
+    """cua-driver occasionally returns negative w/h (e.g. partially laid-out
+    elements). Treat those as no-frame so the sparsity score reflects
+    what the model can actually click."""
+    elems = [
+        UIElement(index=0, role="AXButton", label="x", bounds=(10, 10, -5, -5)),
+    ]
+    assert _ax_sparsity_score(elems) == 1.0
+
+
+def test_browser_app_hints_is_a_frozenset():
+    """If someone tries to mutate _BROWSER_APP_HINTS directly, frozenset
+    raises — the contract is read-only."""
+    assert isinstance(_BROWSER_APP_HINTS, frozenset)
+    try:
+        _BROWSER_APP_HINTS.add("new browser")  # type: ignore[attr-defined]
+    except AttributeError:
+        return
+    raise AssertionError("_BROWSER_APP_HINTS should be immutable")
