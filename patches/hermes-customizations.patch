+        else:
+            return json.dumps({
+                "ok": False,
+                "status": "confirmation_required",
+                "error": "pause and ask the user to confirm this irreversible batch",
+                "task": state,
+            })
+    item_id = str(args.get("task_item_id") or "").strip()
+    step_id = str(args.get("task_step_id") or "").strip()
+    if not item_id:
+        item_id = f"item-{len(completed) + 1}"
+        args["task_item_id"] = item_id
+    if not step_id:
+        step_id = str(args.get("page_action") or action)
+        args["task_step_id"] = step_id
+    if args.get("task_mark_complete") and not args.get("expect_visible_text_contains"):
+        return json.dumps({
+            "ok": False,
+            "status": "expectation_required",
+            "error": "task_mark_complete requires expect_visible_text_contains",
+            "task": state,
+        })
+    key = f"{item_id}:{step_id}"
+    if int((state.get("failed_attempts") or {}).get(key, 0)) >= 2:
+        return json.dumps({
