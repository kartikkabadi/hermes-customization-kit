+# ---------------------------------------------------------------------------
+# Capture defaults — per-app + global overrides for get_window_state
+# ---------------------------------------------------------------------------
+#
+# cua-driver's get_window_state accepts three arguments that bound the AX
+# walk and the response payload (trycua/cua#1961):
+#   * max_elements (default 2000) — hard cap on nodes returned
+#   * max_depth    (default 25)   — AX tree depth cap
+#   * query        (no default)   — case-insensitive substring filter on the
+#                                    markdown tree; element_index values are
+#                                    unchanged, only the rendered Markdown is
+#                                    trimmed
+# Hermes applies these bounds to ordinary apps. Browser captures raise a low
+# configured cap to a bounded high-water mark because Safari/Chromium place
+# browser chrome after the web-content subtree; a depth-first cap of 250 can
+# omit every open tab. Keeping a finite cap avoids pathological web pages
+# turning one capture into an unbounded AX walk. The model-facing response is
+# capped separately after tab controls are promoted.
+#
+# These defaults are read from `computer_use.capture_defaults` in
+# `~/.hermes/config.yaml` (per-app overrides win over `global`):
+#
+#   computer_use:
+#     capture_defaults:
+#       global:
+#         max_elements: 300
+#         max_depth: 15
+#       apps:
+#         Safari:
+#           max_elements: 250
+#           max_depth: 12
+#           query: "button|link|textfield|popup|menuitem|tab|combobox"
+#         "Google Chrome":
+#           max_elements: 250
+#           max_depth: 12
+#           query: "button|link|textfield|popup|menuitem|tab|combobox"
+#
+# The reader fails SAFE — on any config error (missing file, malformed
+# yaml, wrong types) the defaults are empty and the wrapper falls back to
+# the cua-driver built-in caps. A broken config can never silently drop
+# captures.
+
+_CAPTURE_DEFAULTS_CACHE: Optional[Dict[str, Dict[str, Any]]] = None
+# Chromium can place tab-strip radio controls after a 1,200+ element page
+# subtree even though the controls are visually shallow. Keep the driver-side
+# walk wide enough to reach browser chrome; the model-facing useful-element
+# filter still bounds the returned context.
+_BROWSER_CAPTURE_ELEMENT_FLOOR = 2500
+
+
+def _load_capture_defaults() -> Dict[str, Dict[str, Any]]:
+    """Load capture defaults from config.yaml. Returns {global, apps}.
+
+    Cached for the process lifetime — config changes between captures
+    require a Hermes restart (matches the existing telemetry / config
+    caching pattern in this module).
+    """
+    global _CAPTURE_DEFAULTS_CACHE
+    if _CAPTURE_DEFAULTS_CACHE is not None:
+        return _CAPTURE_DEFAULTS_CACHE
+    try:
+        from hermes_cli.config import load_config
+        cfg = load_config() or {}
+    except Exception:
+        _CAPTURE_DEFAULTS_CACHE = {"global": {}, "apps": {}}
+        return _CAPTURE_DEFAULTS_CACHE
+    try:
+        cu = cfg.get("computer_use") or {}
+        defaults = cu.get("capture_defaults") or {}
+        global_d = defaults.get("global") or {}
+        apps_d = defaults.get("apps") or {}
+        # Validate types — anything not a dict gets dropped.
+        if not isinstance(global_d, dict):
+            global_d = {}
+        if not isinstance(apps_d, dict):
+            apps_d = {}
+        result: Dict[str, Dict[str, Any]] = {
+            "global": {k: v for k, v in global_d.items() if k in ("max_elements", "max_depth", "query")},
+            "apps": {
+                str(app_name): {k: v for k, v in app_cfg.items() if k in ("max_elements", "max_depth", "query")}
+                for app_name, app_cfg in apps_d.items()
+                if isinstance(app_cfg, dict)
+            },
+        }
+        # Final per-key validation.
+        for scope in (result["global"], *result["apps"].values()):
+            for k in ("max_elements", "max_depth"):
+                v = scope.get(k)
+                if v is not None:
+                    try:
+                        scope[k] = max(1, min(int(v), 5000))
+                    except (TypeError, ValueError):
+                        scope.pop(k, None)
+            q = scope.get("query")
+            if q is not None and not isinstance(q, str):
+                scope.pop("query", None)
+        _CAPTURE_DEFAULTS_CACHE = result
+        return result
+    except Exception:
+        _CAPTURE_DEFAULTS_CACHE = {"global": {}, "apps": {}}
+        return _CAPTURE_DEFAULTS_CACHE
+
+
+def _resolve_capture_args(app_name: str) -> Dict[str, Any]:
+    """Return the max_elements / max_depth / query overrides to pass to
+    cua-driver's get_window_state for the given app.
+
+    Lookup order: app-specific (case-insensitive substring) → global →
+    empty (cua-driver's own defaults). When the caller passed the literal
+    "screen" / "desktop" sentinel for whole-desktop captures, no app
+    defaults apply.
+    """
+    if not app_name or app_name.lower() in _SCREEN_CAPTURE_SENTINELS:
+        return dict(_load_capture_defaults().get("global") or {})
+    name_lower = app_name.lower()
