+def _surface_browser_tabs(
+    elements: List[UIElement], window_title: str, active_index: Optional[int] = None,
+) -> Tuple[List[UIElement], List[Dict[str, Any]]]:
+    """Put browser tab controls before page content and summarize them.
+
+    Safari exposes its tab strip after the entire web-area subtree. A bounded
+    depth-first capture can therefore look complete while omitting every tab.
+    Browser chrome radio buttons are direct, shallow children of the window;
+    page radio controls are deeper descendants. Preserve driver indices and
+    tokens, changing only model-facing order.
+    """
+    tab_roles = {
+        "AXRadioButton", "AXTab", "AXTabItem",
+        "TabItem", "UIA_TabItemControlType", "ROLE_PAGE_TAB",
+    }
+    web_area_tops = [
+        element.bounds[1]
+        for element in elements
+        if element.role == "AXWebArea"
+        and element.bounds[1] > 0
+        and element.bounds[3] > 0
+    ]
+    web_area_top = min(web_area_tops) if web_area_tops else None
+    tabs = [
+        element for element in elements
+        if element.role in tab_roles
+        and element.attributes.get("depth") in {1, 2, 3}
+        and bool((element.label or "").strip())
+        and (
+            web_area_top is None
+            or element.bounds[1] <= 0
+            or element.bounds[1] < web_area_top
+        )
+    ]
+    if not tabs:
+        return elements, []
+
+    selected_tabs = [tab for tab in tabs if tab.attributes.get("selected") is True]
+    if active_index is not None:
+        active_matches = [tab for tab in tabs if tab.index == active_index]
+    elif selected_tabs:
+        active_matches = selected_tabs
+    else:
+        # Window title is the only active-tab signal on older Safari driver
+        # payloads. With duplicate titles, mark one deterministic candidate
+        # instead of claiming every identical tab is active.
+        active_matches = [next((tab for tab in tabs if tab.label == window_title), tabs[0])]
+    tab_summaries = [
+        {
+            "element": tab.index,
+            "title": tab.label,
+            "active": tab in active_matches,
+            **({"element_token": tab.element_token} if tab.element_token else {}),
+        }
+        for tab in tabs
+    ]
+    tab_indices = {tab.index for tab in tabs}
+    return tabs + [e for e in elements if e.index not in tab_indices], tab_summaries
+
