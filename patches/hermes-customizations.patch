+    def list_tabs(self, app: str) -> Optional[Dict[str, Any]]:
+        """Read Safari tabs through Apple Events without activating Safari."""
+        if sys.platform != "darwin" or app.casefold() not in {
+            "safari", "com.apple.safari",
+        }:
+            return None
+
+        script = r'''const safari = Application("Safari");
+JSON.stringify({
+  running: safari.running(),
+  windows: safari.running() ? safari.windows().map((window, windowIndex) => ({
+    window: windowIndex,
+    currentTabIndex: window.currentTab().index(),
+    tabs: window.tabs().map((tab, tabIndex) => ({
+      index: tabIndex,
+      title: tab.name(),
+      url: tab.url()
+    }))
+  })) : []
+})'''
+        try:
+            proc = subprocess.run(
+                ["osascript", "-l", "JavaScript", "-e", script],
+                capture_output=True,
+                text=True,
+                timeout=5,
+                check=False,
+            )
+            if proc.returncode != 0:
+                return None
+            payload = json.loads(proc.stdout)
+        except (OSError, subprocess.SubprocessError, json.JSONDecodeError):
+            return None
+        if not isinstance(payload, dict):
+            return None
+        if payload.get("running") is False:
+            return {
+                "app": app,
+                "tabs": [],
+                "count": 0,
+                "active_tab": None,
+                "status": "not_running",
+                "source": "platform_semantic",
+            }
+        windows = payload.get("windows")
+        if not isinstance(windows, list):
+            return None
+
+        tabs: List[Dict[str, Any]] = []
+        for window in windows:
+            if not isinstance(window, dict):
+                continue
