+            heading_index = "  - (no Markdown headings; read the full file)"
+        indexed = _scan_context_content(heading_index, path.name)
+        entries.append(
+            f"- `{path}` ({len(content):,} characters)\n"
+            f"  Section index:\n{indexed}"
+        )
+
+    if not entries:
+        return ""
+    return (
+        "# Project Context Reference\n\n"
+        "Authoritative project instructions exist but are not preloaded in "
+        "this shadow projection. Before editing project files, running "
+        "project-specific commands, or making architectural claims, read the "
+        "referenced file with `read_file`. For unrelated tasks, do not load it. "
+        "The file remains the source of truth; this section index is only a "
+        "router. H1/H2 entries include only a bounded lead directive. Heading "
+        "entries use `L<number>`; pass that line number as the `read_file` "
+        "offset when the lead is insufficient.\n\n"
+        + "\n\n".join(entries)
+    )
+
+
+def build_context_files_pointer_prompt(cwd: Optional[str] = None) -> str:
+    """Return only authoritative project-rule locations for sparse routing."""
+    cwd_path = Path(cwd or os.getcwd()).resolve()
+    paths = _context_reference_paths(cwd_path)
+    if not paths:
+        return ""
+    rendered = []
+    for path in paths:
+        try:
+            size = len(path.read_text(encoding="utf-8"))
+        except OSError:
+            continue
+        rendered.append(f"- `{path}` ({size:,} characters)")
+    if not rendered:
+        return ""
+    return (
+        "# Project Context Pointer\n\n"
+        "Authoritative project instructions are query-routed into the current "
+        "turn. If the supplied excerpts are insufficient before project work, "
+        "read the source file. For unrelated tasks, do not load it.\n\n"
+        + "\n".join(rendered)
+    )
+
+
+_CONTEXT_QUERY_STOPWORDS = frozenset({
+    "a", "an", "and", "are", "authoritative", "be", "do", "for", "from",
+    "i", "in", "is", "it", "me", "my", "of", "on", "or", "project",
+    "read", "tell", "the", "this", "to", "what", "with", "you",
+})
+
+
+def build_context_files_query_context(
+    query: str,
+    cwd: Optional[str] = None,
+    *,
+    max_sections: int = 2,
+    max_chars_per_section: int = 2_400,
+) -> str:
+    """Select small project-rule pages relevant to one user turn.
+
+    This is deterministic sparse retrieval for reference-mode experiments: a
+    cheap lexical index chooses H1/H2 sections, then exact source text is
+    injected into only the current user turn. No LLM summary or durable history
+    mutation is involved.
+    """
+    if not isinstance(query, str) or not query.strip():
+        return ""
+    query_terms = {
+        term for term in re.findall(r"[a-z0-9_./-]+", query.lower())
+        if len(term) > 1 and term not in _CONTEXT_QUERY_STOPWORDS
+    }
+    if not query_terms:
+        return ""
+
+    cwd_path = Path(cwd or os.getcwd()).resolve()
+    paths = _context_reference_paths(cwd_path)
+    if not paths:
+        return ""
+
+    candidates = []
+    for path in paths:
+        try:
+            content = path.read_text(encoding="utf-8").strip()
+        except OSError:
+            continue
+        lines = content.splitlines()
+        starts = []
+        in_fence = False
+        for index, line in enumerate(lines):
+            stripped = line.strip()
+            if stripped.startswith(("```", "~~~")):
+                in_fence = not in_fence
+                continue
+            if in_fence:
+                continue
+            match = re.match(r"^(#{1,2})\s+(.+)$", stripped)
+            if match:
+                starts.append((index, stripped))
+        for position, (start, heading) in enumerate(starts):
+            end = starts[position + 1][0] if position + 1 < len(starts) else len(lines)
+            section = "\n".join(lines[start:end]).strip()
+            heading_text = heading.lower()
+            section_text = section.lower()
+            score = sum(
+                8 if term in heading_text else min(3, section_text.count(term))
+                for term in query_terms
+            )
+            if score:
+                candidates.append((score, start + 1, path, section))
+
+    candidates.sort(key=lambda item: (-item[0], item[1], str(item[2])))
+    pages = []
+    for _score, line_number, path, section in candidates[:max(0, max_sections)]:
+        page = section[:max(0, max_chars_per_section)]
+        page = _scan_context_content(page, path.name)
+        pages.append(f"Source: {path} L{line_number}\n{page}")
+    if not pages:
+        return ""
+    return (
+        "[PROJECT CONTEXT PAGES — authoritative source excerpts selected for "
+        "this user turn; follow them for project work]\n"
+        + "\n\n".join(pages)
+        + "\n[/PROJECT CONTEXT PAGES]"
+    )
+
+
