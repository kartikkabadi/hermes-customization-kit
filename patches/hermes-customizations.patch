+def test_sanitize_long_capture_polling_history_has_constant_projected_size():
+    """Superseded read-only polling must not grow the active model context."""
+    from agent.agent_runtime_helpers import sanitize_api_messages
+
+    messages = [{"role": "user", "content": "Watch this window until ready."}]
+    for index in range(100):
+        call_id = f"capture_{index}"
+        messages.extend([
+            {"role": "assistant", "content": None, "tool_calls": [{
+                "id": call_id, "type": "function",
+                "function": {
+                    "name": "computer_use",
+                    "arguments": '{"action":"capture","app":"Safari"}',
+                },
+            }]},
+            {"role": "tool", "name": "computer_use", "tool_call_id": call_id,
+             "content": json.dumps({
+                 "mode": "ax", "snapshot_id": f"snapshot-{index}",
+                 "app": "Safari", "elements": [
+                     {"index": element, "role": "AXStaticText", "label": "waiting" * 20}
+                     for element in range(100)
+                 ],
+             })},
+        ])
+
+    canonical_chars = sum(len(message.get("content") or "") for message in messages)
+    out = sanitize_api_messages(list(messages))
+    projected_chars = sum(len(message.get("content") or "") for message in out)
+
+    assert len(out) == 3  # user + newest capture call/result
+    assert out[-1]["tool_call_id"] == "capture_99"
+    assert canonical_chars / projected_chars > 90
+    assert len(messages) == 201
+    assert "snapshot-0" in messages[2]["content"]
+
