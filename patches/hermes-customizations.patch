+        return {"available": False, "spaces": [], "window_spaces": {}}
+    ids = [int(value) for value in window_ids]
+    script = r'''ObjC.import("Cocoa");
+ObjC.bindFunction("SLSMainConnectionID", ["uint32", []]);
+ObjC.bindFunction("SLSCopyManagedDisplaySpaces", ["id", ["uint32"]]);
+ObjC.bindFunction("SLSCopySpacesForWindows", ["id", ["uint32", "int", "id"]]);
+const cid = $.SLSMainConnectionID();
+const managed = ObjC.deepUnwrap($.SLSCopyManagedDisplaySpaces(cid));
+const windowIds = __WINDOW_IDS__;
+const memberships = {};
+for (const windowId of windowIds) {
+  memberships[String(windowId)] = ObjC.deepUnwrap(
+    $.SLSCopySpacesForWindows(cid, 7, $([windowId]))
+  );
+}
