+def _capture_dedup_fingerprint(cap: Optional[CaptureResult]) -> Optional[str]:
+    """Identify an exact observation, including pixels when they exist.
+
+    ``_capture_fingerprint`` deliberately ignores screenshots because action
+    verification should prefer semantic state.  Capture deduplication has the
+    opposite requirement: a canvas, video, or loading indicator can change
+    while its AX tree stays fixed, so pixels must participate before we call
+    two observations identical.
+    """
+    semantic = _capture_fingerprint(cap)
+    if cap is None:
+        return None
+    image = cap.png_b64 or ""
+    if not semantic and not image:
+        return None
+    canonical = f"{cap.mode}\0{semantic or ''}\0{image}"
+    return hashlib.sha256(canonical.encode("utf-8")).hexdigest()
+
+
+def _remember_capture(
+    backend: ComputerUseBackend,
+    cap: CaptureResult,
+    *,
+    request_signature: Optional[str] = None,
+) -> None:
+    """Keep the last observation and count exact consecutive duplicates."""
+    fingerprint = _capture_dedup_fingerprint(cap)
+    previous = getattr(backend, "_last_capture_dedup_fingerprint", None)
+    previous_request = getattr(backend, "_last_capture_request_signature", None)
+    consecutive = (
+        request_signature is not None
+        and request_signature == previous_request
+        and getattr(backend, "_last_tool_action", None) == "capture"
+    )
+    if fingerprint is not None and consecutive and fingerprint == previous:
+        repeat_count = int(getattr(backend, "_capture_repeat_count", 0)) + 1
+    else:
+        repeat_count = 0
+    setattr(backend, "_capture_repeat_count", repeat_count)
+    setattr(backend, "_last_capture_dedup_fingerprint", fingerprint)
+    setattr(backend, "_last_capture_request_signature", request_signature)
+    setattr(backend, "_last_capture_result", cap)
+    setattr(backend, "_last_capture_at", time.time())
+
+
+def _capture_fingerprint(cap: Optional[CaptureResult]) -> Optional[str]:
+    """Build a stable UI-state fingerprint without hashing screenshot pixels."""
+    if cap is None:
+        return None
+    visible_text = cap.visible_text or cap.meta.get("visible_text")
+    elements = [
+        (e.index, e.role, e.label, tuple(e.bounds))
+        for e in cap.elements
+    ]
+    if not (cap.app or cap.window_title or elements or visible_text or cap.revision):
+        return None
+    canonical = json.dumps(
+        {
+            "revision": cap.revision,
+            "pid": cap.pid,
+            "window_id": cap.window_id,
+            "app": cap.app,
+            "window_title": cap.window_title,
+            "visible_text": visible_text,
+            "elements": elements,
+        },
+        ensure_ascii=False,
+        sort_keys=True,
+        separators=(",", ":"),
+        default=str,
+    )
+    return hashlib.sha256(canonical.encode("utf-8")).hexdigest()
+
+
+def _infer_action_verification(
+    res: ActionResult,
+    before: Optional[CaptureResult],
+    after: CaptureResult,
+) -> None:
+    """Enrich an accepted action with post-capture effect evidence."""
+    if not res.ok:
+        return
+    before_revision = res.before_revision or getattr(before, "revision", None)
+    after_revision = res.after_revision or getattr(after, "revision", None)
+    before_fingerprint = _capture_fingerprint(before)
+    after_fingerprint = _capture_fingerprint(after)
+
+    if before_revision is not None and after_revision is not None:
+        changed = (
+            str(before_revision) != str(after_revision)
+        )
+        source = "driver_revision"
+    elif before_revision is not None or after_revision is not None:
+        changed = None
+        source = "partial_driver_revision"
+    elif before_fingerprint is not None and after_fingerprint is not None:
+        changed = before_fingerprint != after_fingerprint
+        source = "capture_fingerprint"
+    else:
+        # There was not enough information to prove either outcome. Keep the
+        # transport success, but make the uncertainty explicit to the model.
+        changed = None
+        source = "insufficient_observation"
+
+    if before_revision is not None:
+        res.before_revision = str(before_revision)
+    if after_revision is not None:
+        res.after_revision = str(after_revision)
+    # A post-capture is stronger evidence than the driver's transport-level
+    # ``effect=unverifiable`` flag. Promote an observed change to confirmed;
+    # conversely, make a stable observation explicit as a suspected no-op.
+    # Preserve an already trusted driver confirmation if one exists.
+    if changed is not None and not (
+        res.verified is True and res.effect == "confirmed"
+    ):
+        res.verified = changed
+        res.effect = "confirmed" if changed else "suspected_noop"
+        res.status = "ok" if changed else "unverified"
+    verification = {
+        "source": source,
+        "changed": changed,
+        "before_revision": res.before_revision,
+        "after_revision": res.after_revision,
+        "before_visible_text": (
+            getattr(before, "visible_text", None) if before is not None else None
+        ),
+        "after_visible_text": after.visible_text,
+    }
+    res.meta = {**res.meta, "verification": verification}
+
+
+def _redact_tab_inventory(result: Dict[str, Any]) -> Dict[str, Any]:
+    """Remove tab/window content before a semantic inventory reaches a model."""
+    tabs = []
+    for tab in result.get("tabs", []):
+        if not isinstance(tab, dict):
+            continue
+        redacted = dict(tab)
+        for key in ("title", "url"):
+            if key in redacted:
+                redacted[key] = "<redacted>" if redacted.get(key) else ""
+        tabs.append(redacted)
+    active = result.get("active_tab")
+    redacted_active = None
+    if isinstance(active, dict):
+        redacted_active = dict(active)
+        for key in ("title", "url"):
+            if key in redacted_active:
+                redacted_active[key] = "<redacted>" if redacted_active.get(key) else ""
+    return {
+        **result,
+        "window_title": (
+            "<redacted>" if result.get("window_title") else result.get("window_title")
+        ),
+        "tabs": tabs,
+        "active_tab": redacted_active,
+        "content_redacted": True,
+    }
+
+
+def _redact_window_inventory(result: Dict[str, Any]) -> Dict[str, Any]:
+    """Copy an inventory while keeping only structural window identity."""
+    return {
+        **result,
+        "windows": [
+            {
+                **window,
+                "title": "<redacted>" if window.get("title") else "",
+            }
+            for window in result.get("windows", [])
+            if isinstance(window, dict)
+        ],
+        "content_redacted": True,
+    }
