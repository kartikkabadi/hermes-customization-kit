+    action_result = json.dumps({"ok": True, "action": "click", "status": "unverified"})
+    latest_capture = json.dumps({
+        "mode": "som", "snapshot_id": "s2", "app": "Safari",
+        "window_title": "Compose / X", "total_elements": 20,
+        "elements": [{"index": 9, "role": "AXTextArea", "label": "Post text"}],
+    })
+    messages = [
+        {"role": "assistant", "content": None, "tool_calls": [{
+            "id": "capture_1", "type": "function",
+            "function": {"name": "computer_use", "arguments": '{"action":"capture"}'},
+        }]},
+        {"role": "tool", "name": "computer_use", "tool_call_id": "capture_1",
+         "content": first_capture},
+        {"role": "assistant", "content": None, "tool_calls": [{
+            "id": "click_1", "type": "function",
+            "function": {"name": "computer_use", "arguments": '{"action":"click"}'},
+        }]},
+        {"role": "tool", "name": "computer_use", "tool_call_id": "click_1",
+         "content": action_result},
+        {"role": "assistant", "content": None, "tool_calls": [{
+            "id": "capture_2", "type": "function",
+            "function": {"name": "computer_use", "arguments": '{"action":"capture"}'},
+        }]},
+        {"role": "tool", "name": "computer_use", "tool_call_id": "capture_2",
+         "content": latest_capture},
+    ]
+
+    out = sanitize_api_messages(list(messages))
+    tool_messages = [message for message in out if message.get("role") == "tool"]
