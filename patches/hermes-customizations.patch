+                    "uuid": raw_space.get("uuid"),
+                    "desktop_name": f"Desktop {ordinal}",
+                    "mission_control_ordinal": ordinal,
+                    "current": space_id == current_id,
+                    "display_identifier": monitor.get("Display Identifier"),
+                    "display_id": display.get("id"),
+                    "display_name": display.get("name"),
+                })
+        memberships = payload.get("window_spaces") or {}
+        return {
+            "available": True,
+            "spaces": spaces,
+            "window_spaces": {
