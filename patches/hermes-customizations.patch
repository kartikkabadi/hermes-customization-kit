+def _mac_app_bundle_path(bundle_id: Optional[str], name: Optional[str]) -> Optional[Path]:
+    """Resolve an installed bundle without activating it."""
+    if sys.platform != "darwin":
+        return None
+    if bundle_id:
+        query = f"kMDItemCFBundleIdentifier == '{bundle_id}'"
+        try:
+            completed = subprocess.run(
+                ["mdfind", query], capture_output=True, text=True, timeout=3,
+                check=False,
+            )
+            for raw in completed.stdout.splitlines():
+                path = Path(raw.strip())
+                if path.suffix == ".app" and path.is_dir():
+                    return path
+        except (OSError, subprocess.SubprocessError):
+            pass
+    if name:
+        for root in (Path("/Applications"), Path("/System/Applications")):
+            candidate = root / f"{name}.app"
+            if candidate.is_dir():
+                return candidate
+    return None
+
+
+def _detect_app_runtime(bundle_id: Optional[str], name: Optional[str]) -> str:
+    """Classify macOS bundles into the background-control routing classes."""
+    bundle = _mac_app_bundle_path(bundle_id, name)
+    if bundle is None:
+        return "native"
+    frameworks = bundle / "Contents" / "Frameworks"
+    if (frameworks / "Electron Framework.framework").exists():
+        return "electron"
+    executable_dir = bundle / "Contents" / "MacOS"
+    try:
+        executable = next(path for path in executable_dir.iterdir() if path.is_file())
+        with executable.open("rb") as stream:
+            probe = stream.read(32 * 1024 * 1024)
+        if b"TAURI_WEBVIEW_AUTOMATION" in probe or b"tauri://localhost" in probe:
+            return "tauri"
+    except (OSError, StopIteration):
+        pass
+    return "native"
+
+
+def _mac_app_name_aliases(name: str) -> set[str]:
+    """Return display and executable names for one installed macOS app."""
+    aliases = {name.strip().casefold()}
+    bundle = _mac_app_bundle_path(None, name)
+    if bundle is None:
+        return aliases
+    try:
+        with (bundle / "Contents" / "Info.plist").open("rb") as stream:
+            info = plistlib.load(stream)
+        for key in ("CFBundleExecutable", "CFBundleDisplayName", "CFBundleName"):
+            value = str(info.get(key) or "").strip()
+            if value:
+                aliases.add(value.casefold())
+    except (OSError, plistlib.InvalidFileException):
+        pass
+    return aliases
+
