+            current_tab_index = int(window.get("currentTabIndex", 0))
+            for tab in window.get("tabs", []):
+                if not isinstance(tab, dict):
+                    continue
+                tab_index = int(tab.get("index", 0))
+                tabs.append({
+                    "id": f"safari:w{window_index}:t{tab_index}",
+                    "window": window_index,
+                    "index": tab_index,
+                    "title": str(tab.get("title") or ""),
+                    "url": str(tab.get("url") or ""),
+                    "active": window_index == 0 and tab_index + 1 == current_tab_index,
+                })
