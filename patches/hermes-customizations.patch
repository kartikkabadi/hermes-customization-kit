+                for key, values in memberships.items() if isinstance(values, list)
+            },
+            "source": "macos_skylight_read_only",
+            "ordering": "managed_display_then_space_order",
+        }
+    except (OSError, subprocess.SubprocessError, json.JSONDecodeError, TypeError, ValueError):
+        return {"available": False, "spaces": [], "window_spaces": {}}
