+def _mac_display_inventory() -> List[Dict[str, Any]]:
+    """Read NSScreen layout without changing focus, Spaces, or app state."""
+    if sys.platform != "darwin":
+        return []
+    script = r'''ObjC.import("AppKit");
+const screens = $.NSScreen.screens.js;
+const mainHeight = Number($.NSScreen.mainScreen.frame.size.height);
+JSON.stringify(screens.map((screen, index) => {
+  const frame = screen.frame;
+  return {
+    id: "display-" + index,
+    index: index,
+    name: ObjC.unwrap(screen.localizedName),
+    main: screen.isEqual($.NSScreen.mainScreen),
+    scale_factor: Number(screen.backingScaleFactor),
+    bounds: {
+      x: Number(frame.origin.x),
+      y: mainHeight - Number(frame.origin.y + frame.size.height),
+      width: Number(frame.size.width),
+      height: Number(frame.size.height)
+    }
+  };
+}))'''
+    try:
+        proc = subprocess.run(
+            ["osascript", "-l", "JavaScript", "-e", script],
+            capture_output=True, text=True, timeout=5, check=False,
+        )
+        payload = json.loads(proc.stdout) if proc.returncode == 0 else []
+        return [item for item in payload if isinstance(item, dict)]
+    except (OSError, subprocess.SubprocessError, json.JSONDecodeError):
+        return []
+
+
+def _mac_frontmost_application() -> Optional[Dict[str, Any]]:
+    """Read the OS-owned active application without activating anything."""
+    if sys.platform != "darwin":
+        return None
+    script = r'''ObjC.import("AppKit");
+const app = $.NSWorkspace.sharedWorkspace.frontmostApplication;
+JSON.stringify({
+  pid: Number(app.processIdentifier),
+  name: ObjC.unwrap(app.localizedName),
+  bundle_id: ObjC.unwrap(app.bundleIdentifier)
+});'''
+    try:
+        proc = subprocess.run(
+            ["osascript", "-l", "JavaScript", "-e", script],
+            capture_output=True, text=True, timeout=3, check=False,
+        )
+        payload = json.loads(proc.stdout) if proc.returncode == 0 else None
+        if not isinstance(payload, dict) or not payload.get("pid"):
+            return None
+        return {
+            "pid": int(payload["pid"]),
+            "name": str(payload.get("name") or ""),
+            "bundle_id": str(payload.get("bundle_id") or ""),
+        }
+    except (OSError, subprocess.SubprocessError, json.JSONDecodeError, TypeError, ValueError):
+        return None
+
