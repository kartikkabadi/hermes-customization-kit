+            continue
+        for call in message.get("tool_calls") or []:
+            call_id = _extract_tool_call_id(call)
+            name, raw_args = _extract_tool_call_name_and_args(call)
+            try:
+                args = json.loads(raw_args) if raw_args else {}
+            except (TypeError, json.JSONDecodeError):
+                args = {}
+            if call_id:
+                call_map[call_id] = (name, args if isinstance(args, dict) else {})
+
+    for message in messages:
+        if message.get("role") != "tool":
+            continue
+        name, args = call_map.get(str(message.get("tool_call_id") or ""), ("", {}))
+        if name not in {"computer_use", "computer_task"}:
+            continue
+        content = message.get("content")
+        if not isinstance(content, str):
+            continue
+        try:
+            receipt = json.loads(content)
+        except (TypeError, json.JSONDecodeError):
+            continue
+        if not isinstance(receipt, dict):
+            continue
+        controller = receipt.get("controller")
+        controller = controller if isinstance(controller, dict) else {}
+        verified = bool(
+            receipt.get("verified") is True
+            or receipt.get("effect_verified") is True
+            or controller.get("expectation_matched") is True
+        )
+        if not verified:
+            continue
+        action = str(args.get("action") or receipt.get("action") or name)
+        stable_id = (
+            args.get("item_id") or args.get("task_item_id") or args.get("tab_id")
+            or receipt.get("item_id") or ""
+        )
+        count = controller.get("completed_count")
+        target = controller.get("target_count")
+        detail = f"{name}.{action}"
+        if stable_id:
+            detail += f" id={stable_id}"
+        if count is not None and target is not None:
+            detail += f" count={count}/{target}"
+        add(detail)
+
+    if not entries:
+        return clean_summary
