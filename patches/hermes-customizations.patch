+    newest_index = capture_indices[-1]
+    drop_indices: set[int] = set()
+    for index in capture_indices[:-1]:
+        message = messages[index]
+        call_id = message.get("tool_call_id")
+        arguments = calls_by_id.get(call_id, {}) if isinstance(call_id, str) else {}
+        assistant_index = (
