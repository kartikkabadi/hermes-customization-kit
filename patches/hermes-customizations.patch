+def _foreground_observation(app: Optional[str]) -> Dict[str, Any]:
+    """Shape an authoritative, privacy-safe foreground receipt."""
+    frontmost = _mac_frontmost_application()
+    observed_at = time.time()
+    if frontmost is None:
+        return {
+            "available": False,
+            "target_is_frontmost": None,
+            "observed_at": observed_at,
+            "source": "unavailable",
+        }
+    if app:
+        aliases = _mac_app_name_aliases(app)
+        name = str(frontmost.get("name") or "").casefold()
+        bundle_id = str(frontmost.get("bundle_id") or "").casefold()
+        target_is_frontmost = any(
+            alias == name
+            or alias == bundle_id
+            or bundle_id.endswith(f".{alias}")
+            for alias in aliases
+        )
+        return {
+            "available": True,
+            "target_is_frontmost": target_is_frontmost,
+            "observed_at": observed_at,
+            "source": "macos_nsworkspace",
+        }
+    return {
+        "available": True,
+        "pid": frontmost["pid"],
+        "name": frontmost["name"],
+        "bundle_id": frontmost["bundle_id"],
+        "observed_at": observed_at,
+        "source": "macos_nsworkspace",
+    }
