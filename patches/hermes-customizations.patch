+    def select_tab(self, app: str, tab_id: str) -> Optional[Dict[str, Any]]:
+        """Select one Safari tab by the stable ID returned from ``list_tabs``."""
+        if sys.platform != "darwin" or app.casefold() not in {
+            "safari", "com.apple.safari",
+        }:
+            return None
+        match = re.fullmatch(r"safari:w(\d+):t(\d+)", tab_id)
+        if match is None:
+            return {
+                "ok": False,
+                "action": "select_tab",
+                "app": app,
+                "status": "invalid_target",
+                "verified": False,
+                "error": "tab_id is not a Safari stable tab ID from list_tabs",
+                "source": "platform_semantic",
+            }
+        window_index, tab_index = (int(value) for value in match.groups())
+        before = self.list_tabs(app)
+        if not isinstance(before, dict) or before.get("status") != "ok":
+            return {
+                "ok": False,
+                "action": "select_tab",
+                "app": app,
+                "status": (before or {}).get("status", "unavailable"),
+                "verified": False,
+                "source": "platform_semantic",
+            }
+        target = next(
+            (tab for tab in before.get("tabs", []) if tab.get("id") == tab_id),
+            None,
+        )
+        if target is None:
+            return {
+                "ok": False,
+                "action": "select_tab",
+                "app": app,
+                "status": "stale_target",
+                "verified": False,
+                "error": "tab no longer exists; call list_tabs for fresh IDs",
+                "source": "platform_semantic",
+            }
+
+        script = f'''const safari = Application("Safari");
+const window = safari.windows()[{window_index}];
+window.currentTab = window.tabs()[{tab_index}];
+delay(0.1);'''
+        try:
+            proc = subprocess.run(
+                ["osascript", "-l", "JavaScript", "-e", script],
+                capture_output=True,
+                text=True,
+                timeout=5,
+                check=False,
+            )
+        except (OSError, subprocess.SubprocessError):
+            proc = None
+        if proc is None or proc.returncode != 0:
+            return {
+                "ok": False,
+                "action": "select_tab",
+                "app": app,
+                "status": "transient_error",
+                "verified": False,
+                "error": "Safari rejected the background tab selection",
+                "source": "platform_semantic",
+            }
