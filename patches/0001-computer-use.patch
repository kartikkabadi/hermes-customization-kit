+def _mac_app_name_aliases(name: str) -> set[str]:
+    """Return display and executable names for one installed macOS app."""
+    aliases = {name.strip().casefold()}
+    bundle = _mac_app_bundle_path(None, name)
+    if bundle is None:
+        return aliases
+    try:
+        with (bundle / "Contents" / "Info.plist").open("rb") as stream:
+            info = plistlib.load(stream)
+        for key in ("CFBundleExecutable", "CFBundleDisplayName", "CFBundleName"):
+            value = str(info.get(key) or "").strip()
+            if value:
+                aliases.add(value.casefold())
+    except (OSError, plistlib.InvalidFileException):
+        pass
+    return aliases
+
