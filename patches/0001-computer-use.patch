+def _mac_app_surface_profile(name: str) -> Dict[str, Any]:
+    """Classify an installed macOS app without launching or activating it."""
+    profile: Dict[str, Any] = {
+        "surface_kind": "windowed_or_unknown",
+        "running": None,
+    }
+    if sys.platform != "darwin":
+        return profile
+    bundle = _mac_app_bundle_path(None, name)
+    if bundle is None:
+        return profile
+    try:
+        with (bundle / "Contents" / "Info.plist").open("rb") as stream:
+            info = plistlib.load(stream)
+    except (OSError, plistlib.InvalidFileException):
+        return profile
+    is_agent = bool(info.get("LSUIElement"))
+    is_background_only = bool(info.get("LSBackgroundOnly"))
+    if is_agent:
+        profile["surface_kind"] = "menu_bar"
+    elif is_background_only:
+        profile["surface_kind"] = "background_only"
+    executable = str(info.get("CFBundleExecutable") or "").strip()
+    if executable:
+        executable_path = str(bundle / "Contents" / "MacOS" / executable)
+        try:
+            completed = subprocess.run(
+                ["/usr/bin/pgrep", "-f", f"^{re.escape(executable_path)}( |$)"],
+                check=False, capture_output=True, text=True, timeout=1.0,
+            )
+            pids = [
+                int(line) for line in completed.stdout.splitlines()
+                if line.strip().isdigit()
+            ]
+            profile["running"] = bool(pids)
+            if pids:
+                profile["pids"] = pids[:8]
+        except (OSError, subprocess.TimeoutExpired):
+            pass
+    return profile
