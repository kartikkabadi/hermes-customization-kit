+def _resolve_capture_args(app_name: str) -> Dict[str, Any]:
+    """Return the max_elements / max_depth / query overrides to pass to
+    cua-driver's get_window_state for the given app.
+
+    Lookup order: app-specific (case-insensitive substring) → global →
+    empty (cua-driver's own defaults). When the caller passed the literal
+    "screen" / "desktop" sentinel for whole-desktop captures, no app
+    defaults apply.
+    """
+    if not app_name or app_name.lower() in _SCREEN_CAPTURE_SENTINELS:
+        return dict(_load_capture_defaults().get("global") or {})
+    name_lower = app_name.lower()
+    apps = _load_capture_defaults().get("apps") or {}
+    for configured_name, cfg in apps.items():
+        if configured_name.lower() in name_lower or name_lower in configured_name.lower():
+            return {**_load_capture_defaults().get("global", {}), **cfg}
+    return dict(_load_capture_defaults().get("global") or {})
