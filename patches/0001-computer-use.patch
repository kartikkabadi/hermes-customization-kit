+def _ax_sparsity_score(elements: List[UIElement]) -> float:
+    """Return the fraction of surfaced elements with no usable frame.
+
+    0.0 = every element has a frame, 1.0 = no element does. The model
+    can't pixel-click into an element with no bounds, so a high
+    sparsity score means the AX path is unreliable and the page tool
+    (CSS selectors) is the better bet for browser apps.
+    """
+    if not elements:
+        return 0.0
+    no_frame = sum(
+        1 for e in elements
+        if e.bounds == (0, 0, 0, 0) or (e.bounds[2] <= 0 and e.bounds[3] <= 0)
+    )
+    return no_frame / len(elements)
