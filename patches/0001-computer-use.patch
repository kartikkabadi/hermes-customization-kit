+def handle_computer_task(args: Dict[str, Any], **kwargs) -> Any:
+    """Small-model-friendly facade over the shared deterministic task state."""
+    action = str(args.get("action") or "").strip().lower()
+    mapped = {
+        "start": "task_start",
+        "status": "task_status",
+        "complete": "task_complete",
+        "confirm": "task_confirm",
+        "reset": "task_reset",
+    }.get(action)
+    if mapped is None:
+        return json.dumps({"error": "action must be start|status|complete|confirm|reset"})
+    forwarded: Dict[str, Any] = {"action": mapped}
+    if args.get("task_id") is not None:
+        forwarded["task_id"] = args["task_id"]
+    if args.get("goal") is not None:
+        forwarded["task_goal"] = args["goal"]
+    if args.get("target_count") is not None:
+        forwarded["task_target_count"] = args["target_count"]
+    if args.get("item_id") is not None:
+        forwarded["task_item_id"] = args["item_id"]
+    if args.get("expect_visible_text_contains") is not None:
+        forwarded["expect_visible_text_contains"] = args["expect_visible_text_contains"]
+    if args.get("irreversible") is not None:
+        forwarded["task_irreversible"] = args["irreversible"]
+    if args.get("user_has_confirmed") is not None:
+        forwarded["user_has_confirmed_irreversible"] = args["user_has_confirmed"]
+    return handle_computer_use(forwarded, **kwargs)
