+def _free_loopback_port() -> int:
+    """Reserve an ephemeral port long enough to choose a launch argument."""
+    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
+        sock.bind(("127.0.0.1", 0))
