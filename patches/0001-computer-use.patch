+def _normalize_task_id(value: str) -> str:
+    value = re.sub(r"[^a-z0-9._-]+", "-", (value or "").strip().lower())
+    return value.strip("-._")[:96]
+
+
+def _derived_task_id(goal: str) -> str:
+    slug = _normalize_task_id(goal)[:48] or "computer-work"
+    digest = hashlib.sha256(goal.strip().casefold().encode("utf-8")).hexdigest()[:12]
+    return f"{slug}-{digest}"
+
+
