+def _controller_preflight(
+    backend: ComputerUseBackend, action: str, args: Dict[str, Any],
+) -> Optional[str]:
+    """Enforce exact-count and retry invariants before a repeated-task mutation."""
+    state = getattr(backend, "_controller_task", None)
