+def _mac_space_inventory(
+    window_ids: List[int], displays: List[Dict[str, Any]],
+) -> Dict[str, Any]:
+    """Read Mission Control topology and window membership without switching Spaces.
+
+    SkyLight is a private, read-only API here, so failure is an expected
+    capability result rather than a reason to guess from window visibility.
+    """
+    if sys.platform != "darwin":
+        return {"available": False, "spaces": [], "window_spaces": {}}
+    ids = [int(value) for value in window_ids]
+    script = r'''ObjC.import("Cocoa");
+ObjC.bindFunction("SLSMainConnectionID", ["uint32", []]);
+ObjC.bindFunction("SLSCopyManagedDisplaySpaces", ["id", ["uint32"]]);
+ObjC.bindFunction("SLSCopySpacesForWindows", ["id", ["uint32", "int", "id"]]);
+const cid = $.SLSMainConnectionID();
+const managed = ObjC.deepUnwrap($.SLSCopyManagedDisplaySpaces(cid));
+const windowIds = __WINDOW_IDS__;
+const memberships = {};
+for (const windowId of windowIds) {
+  memberships[String(windowId)] = ObjC.deepUnwrap(
+    $.SLSCopySpacesForWindows(cid, 7, $([windowId]))
+  );
+}
+JSON.stringify({managed: managed, window_spaces: memberships});'''.replace(
+        "__WINDOW_IDS__", json.dumps(ids),
+    )
+    try:
+        proc = subprocess.run(
+            ["osascript", "-l", "JavaScript", "-e", script],
+            capture_output=True, text=True, timeout=5, check=False,
+        )
+        payload = json.loads(proc.stdout) if proc.returncode == 0 else {}
+        managed = payload.get("managed") if isinstance(payload, dict) else None
+        if not isinstance(managed, list):
+            return {"available": False, "spaces": [], "window_spaces": {}}
+
+        spaces: List[Dict[str, Any]] = []
+        ordinal = 0
+        for display_index, monitor in enumerate(managed):
+            if not isinstance(monitor, dict):
+                continue
+            display = displays[display_index] if display_index < len(displays) else {}
+            current = monitor.get("Current Space") or {}
+            current_id = current.get("ManagedSpaceID", current.get("id64"))
+            for raw_space in monitor.get("Spaces") or []:
+                if not isinstance(raw_space, dict) or raw_space.get("type", 0) != 0:
+                    continue
+                ordinal += 1
+                space_id = raw_space.get("ManagedSpaceID", raw_space.get("id64"))
+                spaces.append({
+                    "id": int(space_id),
+                    "uuid": raw_space.get("uuid"),
+                    "desktop_name": f"Desktop {ordinal}",
+                    "mission_control_ordinal": ordinal,
+                    "current": space_id == current_id,
+                    "display_identifier": monitor.get("Display Identifier"),
+                    "display_id": display.get("id"),
+                    "display_name": display.get("name"),
+                })
+        memberships = payload.get("window_spaces") or {}
+        return {
+            "available": True,
+            "spaces": spaces,
+            "window_spaces": {
+                str(key): [int(value) for value in values if isinstance(value, int)]
+                for key, values in memberships.items() if isinstance(values, list)
+            },
+            "source": "macos_skylight_read_only",
+            "ordering": "managed_display_then_space_order",
+        }
+    except (OSError, subprocess.SubprocessError, json.JSONDecodeError, TypeError, ValueError):
+        return {"available": False, "spaces": [], "window_spaces": {}}
+
