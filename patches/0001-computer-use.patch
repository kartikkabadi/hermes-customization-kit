+    # string rather than structuredContent.tree_markdown.
+    if isinstance(raw_data, str):
+        try:
+            parsed = json.loads(raw_data)
+        except (TypeError, json.JSONDecodeError):
+            parsed = None
+        if isinstance(parsed, dict):
+            for key in ("tree_markdown", "tree", "accessibility_tree"):
+                scan_tree(parsed.get(key))
