--- /dev/null
+++ b/tests/computer_use/test_gws_empty_detection.py
@@ -0,0 +1,157 @@
+"""Test get_window_state empty-result detection and the EAGAIN
+screenshot-missing recovery path.
+
+The cua-driver MCP bridge can lose the heavy screenshot payload
+when its non-blocking unix socket is congested (EAGAIN). Pre-fix
+the wrapper only detected the "completely empty" case and missed
+the much more common "kept the tree, dropped the screenshot"
+case — the model got a 150KB markdown tree and a 0x0 image.
+
+Refs: branch fix/computer-use-safari, fix #5 of 6.
+"""
+
+from __future__ import annotations
+
+import os
+import sys
+
+sys.path.insert(0, os.path.join(os.path.dirname(__file__), "..", ".."))
+
+from tools.computer_use.cua_backend import (  # noqa: E402
+    _gws_is_empty,
+    _gws_missing_screenshot,
+)
+
+
+def test_is_empty_when_completely_blank():
+    """No images, no structured content, no data — the fully empty case."""
+    assert _gws_is_empty({"images": [], "structuredContent": {}, "data": ""})
+
+
+def test_is_empty_when_data_is_dict():
+    """data is sometimes a dict (the lean dedup'd payload from Fix #1).
+    That should NOT count as a tree — we need a string with content."""
+    out = {
+        "images": [],
+        "structuredContent": {},
+        "data": {"element_count": 5, "tree_markdown": ""},
+    }
+    assert _gws_is_empty(out)
+
+
+def test_is_not_empty_with_image():
+    out = {"images": ["A" * 100], "structuredContent": {}, "data": ""}
+    assert not _gws_is_empty(out)
+
+
+def test_is_not_empty_with_structured_elements():
+    out = {"images": [], "structuredContent": {"elements": [{"element_index": 0}]}, "data": ""}
+    assert not _gws_is_empty(out)
+
+
+def test_is_not_empty_with_structured_screenshot():
+    out = {"images": [], "structuredContent": {"screenshot_png_b64": "A" * 100}, "data": ""}
+    assert not _gws_is_empty(out)
+
+
+def test_is_not_empty_with_screenshot_file_path():
+    out = {"images": [], "structuredContent": {"screenshot_file_path": "/tmp/x.png"}, "data": ""}
+    assert not _gws_is_empty(out)
+
+
+def test_is_not_empty_with_markdown_tree():
+    """A markdown tree in `data` is the legacy cua-driver shape — must
+    also count as non-empty."""
+    out = {
+        "images": [],
+        "structuredContent": {},
+        "data": "3 elements\n- [0] AXWindow \"Hello\"",
+    }
+    assert not _gws_is_empty(out)
+
+
+# ----- _gws_missing_screenshot: the EAGAIN case ---------------------
+
+
+def test_missing_screenshot_with_tree():
+    """Tree present (structuredContent.elements), no screenshot anywhere."""
+    out = {
+        "images": [],
+        "structuredContent": {"elements": [{"element_index": 0}, {"element_index": 1}]},
+        "data": "",
+    }
+    assert _gws_missing_screenshot(out)
+
+
+def test_missing_screenshot_with_markdown_tree():
+    """Tree present as legacy markdown dump, no screenshot."""
+    out = {
+        "images": [],
+        "structuredContent": {},
+        "data": "3 elements\n- [0] AXWindow \"Hello\"",
+    }
+    assert _gws_missing_screenshot(out)
+
+
+def test_not_missing_when_image_present():
+    out = {
+        "images": ["A" * 100],
+        "structuredContent": {"elements": [{"element_index": 0}]},
+        "data": "",
+    }
+    assert not _gws_missing_screenshot(out)
+
+
+def test_not_missing_when_structured_screenshot_present():
+    out = {
+        "images": [],
+        "structuredContent": {
+            "elements": [{"element_index": 0}],
+            "screenshot_png_b64": "A" * 100,
+        },
+        "data": "",
+    }
+    assert not _gws_missing_screenshot(out)
+
+
+def test_not_missing_when_fully_empty():
+    """No tree AND no screenshot — that's the _gws_is_empty case, not
+    _gws_missing_screenshot. Different fix, different function."""
+    out = {"images": [], "structuredContent": {}, "data": ""}
+    assert not _gws_missing_screenshot(out)
+
+
+def test_not_missing_when_no_screenshot_and_no_tree():
+    out = {
+        "images": [],
+        "structuredContent": {},
+        "data": "",
+    }
+    assert not _gws_missing_screenshot(out)
+
+
+# ----- both checks together: the EAGAIN case should retry -----------
+
+
+def test_eagain_case_triggers_retry():
+    """The exact Safari-EAGAIN signature: structured elements present,
+    no screenshot, no data. _gws_is_empty returns False (we have a
+    tree), _gws_missing_screenshot returns True. The wrapper retries."""
+    out = {
+        "images": [],
+        "structuredContent": {
+            "elements": [{"element_index": i, "role": "AXLink", "label": "x"} for i in range(100)],
+        },
+        "data": "",
+    }
+    assert not _gws_is_empty(out), "has elements → not empty"
+    assert _gws_missing_screenshot(out), "no screenshot → trigger retry"
+
+
+def test_vision_capture_eagain():
+    """The vision path is image-only (no tree) — the same EAGAIN would
+    also drop the image. _gws_is_empty correctly flags it; the vision
+    path's existing CLI fallback (which already runs) handles it."""
+    out = {"images": [], "structuredContent": {}, "data": ""}
+    assert _gws_is_empty(out)
+    assert not _gws_missing_screenshot(out)
