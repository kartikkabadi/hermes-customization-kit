+    item_id = str(args.get("task_item_id") or "").strip()
+    step_id = str(args.get("task_step_id") or "").strip()
+    expected = str(args.get("expect_visible_text_contains") or "").strip()
+    visible = str(payload.get("visible_text") or payload.get("summary") or "")
+    expectation_matched = bool(expected and expected.casefold() in visible.casefold())
