+def _looks_like_cua_payload(parsed: Any) -> bool:
+    """Heuristic: does this parsed JSON value look like a cua-driver
+    per-tool payload (a top-level dict whose keys overlap with the
+    known payload vocabulary)?
+
+    A list at the top level is treated as a payload (cua-driver uses
+    list-typed returns for a few tools). A bare string or number is
+    not. A dict that looks like a status / error reply (only `ok` /
+    `success` / `error` / `message` / `hint` / `action` keys) is NOT
+    a payload — that would swallow a tool's normal text reply and
+    break consumers that read the legacy `data` field.
+    """
+    if isinstance(parsed, list):
+        return True
+    if not isinstance(parsed, dict):
+        return False
+    # Common status / error shapes that should NOT be promoted. A dict
+    # whose keys are entirely a subset of {ok, success, error, message,
+    # msg, hint, action, isError, status} is a reply, not a payload.
+    status_keys = {"ok", "success", "error", "message", "msg", "hint", "action", "isError", "status"}
+    keys = set(parsed.keys())
+    if keys and keys.issubset(status_keys):
+        return False
+    return True
 
 
