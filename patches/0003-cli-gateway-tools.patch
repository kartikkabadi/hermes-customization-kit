+def is_goal_continuation_prompt(value: Any) -> bool:
+    """Return whether *value* is an internal standing-goal turn.
+
+    Goal continuations deliberately travel through the same user-role/FIFO
+    path as real messages for prompt-cache stability.  This marker is the
+    single cross-surface discriminator used by CLI, TUI, and gateways so a
+    genuine user interruption pauses the autonomous loop instead of being
+    mistaken for another self-issued turn.
+    """
+    return isinstance(value, str) and value.startswith(
+        "[Continuing toward your standing goal]\n"
+    )
