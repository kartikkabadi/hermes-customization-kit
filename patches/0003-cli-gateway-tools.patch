--- a/hermes_cli/main.py
+++ b/hermes_cli/main.py
@@ -12528,6 +12528,48 @@ def _should_background_mcp_startup(args) -> bool:
     return args.command in {None, "chat", "rl"}
 
 
+def _requested_toolsets_need_mcp(args) -> bool:
+    """Return whether this launch can actually use configured MCP tools.
+
+    An explicit toolset allowlist is a strong scope boundary. Starting every
+    configured MCP server before building a one-tool ``-t computer_use`` agent
+    adds retries, process churn, and shutdown work even though those tools are
+    filtered out immediately afterwards. Server names are valid dynamic
+    toolset names, so retain discovery when a caller explicitly names one (or
+    requests the unrestricted ``all``/``*`` set).
+    """
+    raw = getattr(args, "toolsets", None)
+    if raw is None:
+        return True
+    if isinstance(raw, str):
+        requested = {part.strip().lower() for part in raw.split(",") if part.strip()}
+    elif isinstance(raw, (list, tuple, set, frozenset)):
+        requested = {
+            part.strip().lower()
+            for value in raw
+            for part in str(value).split(",")
+            if part.strip()
+        }
+    else:
+        requested = {str(raw).strip().lower()} if str(raw).strip() else set()
+    if not requested or requested & {"all", "*"}:
+        return True
+    try:
+        from hermes_cli.config import read_raw_config
+
+        configured = (read_raw_config() or {}).get("mcp_servers") or {}
+        server_names = {
+            str(name).strip().lower()
+            for name in configured
+            if str(name).strip()
+        }
+        return bool(requested & server_names)
+    except Exception:
+        # A config-read failure must not silently remove explicitly requested
+        # integrations. Fall back to discovery and preserve the old behavior.
+        return True
+
+
