+def _route_tools_for_query(
+    tool_defs: List[Dict[str, Any]],
+    query: str,
+    *,
+    limit: int = 4,
+) -> Tuple[List[Dict[str, Any]], List[Dict[str, Any]]]:
+    """Split deferred candidates into query-visible and still-deferred tools."""
+    stopwords = {
+        "and", "anything", "minimum", "modify", "report", "supported",
+        "the", "this", "version", "with", "without",
+    }
+    query_terms = {
+        term for term in re.findall(r"[a-z0-9]+", (query or "").lower())
+        if len(term) > 1 and term not in stopwords
+    }
+    if not query_terms:
+        return [], tool_defs
+    scored = []
+    for position, tool_def in enumerate(tool_defs):
+        function = tool_def.get("function") or {}
+        name = str(function.get("name") or "")
+        name_terms = set(re.findall(r"[a-z0-9]+", name.lower().replace("_", " ")))
+        description = str(function.get("description") or "").lower()
+        name_overlap = query_terms & name_terms
+        description_overlap = {term for term in query_terms if term in description}
+        score = 10 * len(name_overlap) + 2 * len(description_overlap)
+        if name_overlap or len(description_overlap) >= 2:
+            scored.append((score, position, bool(name_overlap), tool_def))
+    if any(item[2] for item in scored):
+        scored = [item for item in scored if item[2]]
+    scored.sort(key=lambda item: (-item[0], item[1]))
+    routed_ids = {id(item[3]) for item in scored[:max(0, limit)]}
+    return (
+        [tool_def for tool_def in tool_defs if id(tool_def) in routed_ids],
+        [tool_def for tool_def in tool_defs if id(tool_def) not in routed_ids],
+    )
+
